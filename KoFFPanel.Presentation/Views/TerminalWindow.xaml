<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.TerminalWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding WindowTitle}"
                 Height="700"
                 Width="1100"
                 MinHeight="500"
                 MinWidth="850"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.Resources>
            <Style TargetType="ui:Snackbar">
                <Setter Property="Background"
                        Value="#1A1C23" />
                <Setter Property="Foreground"
                        Value="#00ff88" />
                <Setter Property="BorderBrush"
                        Value="#3300ff88" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="Padding"
                        Value="16,12" />
                <Setter Property="Margin"
                        Value="0,0,0,20" />
                <Setter Property="MaxWidth"
                        Value="400" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#08FFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <ui:TitleBar Title="{Binding WindowTitle}"
                         Background="Transparent"
                         Foreground="White"
                         Padding="12,8">
                <ui:TitleBar.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="#00ff88"
                                     Margin="0,0,10,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00ff88"
                                                      BlurRadius="8"
                                                      ShadowDepth="0" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="{Binding ConnectionInfo}"
                                       Foreground="#a0aabf"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter, Segoe UI" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="100,0,20,0"
                                    Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:SymbolIcon Symbol="Pulse24"
                                           Foreground="#39ff14"
                                           FontSize="18"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PingMs, StringFormat='{}{0} ms'}"
                                       Foreground="#39ff14"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,20,0"
                                       VerticalAlignment="Center" />

                            <ui:SymbolIcon Symbol="DeveloperBoard24"
                                           Foreground="#2962ff"
                                           FontSize="18"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CpuUsage, StringFormat='CPU: {0}%'}"
                                       Foreground="#a0aabf"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,20,0"
                                       VerticalAlignment="Center" />

                            <ui:SymbolIcon Symbol="Board24"
                                           Foreground="#b026ff"
                                           FontSize="18"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RamUsage, StringFormat='RAM: {0}%'}"
                                       Foreground="#a0aabf"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,20,0"
                                       VerticalAlignment="Center" />

                            <ui:SymbolIcon Symbol="Database24"
                                           Foreground="#00e676"
                                           FontSize="18"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SsdUsage, StringFormat='SSD: {0}%'}"
                                       Foreground="#a0aabf"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </ui:TitleBar.Header>
            </ui:TitleBar>
        </Border>

        <Grid Grid.Row="1"
              Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"
                                  MinWidth="250"
                                  MaxWidth="500" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#08FFFFFF"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem"
                                   BasedOn="{StaticResource {x:Type TabItem}}">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Padding"
                                        Value="12,8" />
                                <Setter Property="Cursor"
                                        Value="Hand" />
                            </Style>
                        </TabControl.Resources>

                        <TabItem ToolTip="SFTP Проводник">
                            <TabItem.Header>
                                <ui:SymbolIcon Symbol="Folder24"
                                               FontSize="20"
                                               Foreground="#ffb86c" />
                            </TabItem.Header>
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="Transparent"
                                        Padding="16,8">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="FolderOpen24"
                                                       Filled="True"
                                                       Foreground="#ffaa00"
                                                       Margin="0,0,10,0"
                                                       FontSize="18" />
                                        <TextBlock Text="{Binding CurrentDirectory}"
                                                   Foreground="#39ff14"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Consolas"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Cursor="Hand"
                                                   ToolTip="Двойной клик - Копировать путь"
                                                   MouseLeftButtonDown="CurrentDirectory_MouseDoubleClick" />
                                    </StackPanel>
                                </Border>

                                <ListView Grid.Row="1"
                                          ItemsSource="{Binding Files}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Margin="0,4,0,0">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding"
                                                    Value="0" />
                                            <Setter Property="Cursor"
                                                    Value="Hand" />
                                            <Setter Property="HorizontalContentAlignment"
                                                    Value="Stretch" />
                                            <EventSetter Event="MouseDoubleClick"
                                                         Handler="ExplorerItem_DoubleClick" />
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent"
                                                    Padding="16,6">
                                                <Border.ContextMenu>
                                                    <ContextMenu Background="#1c1e27"
                                                                 Foreground="White"
                                                                 BorderBrush="#2a2d3d">
                                                        <MenuItem Header="Открыть"
                                                                  Click="MenuItem_Open_Click"
                                                                  Foreground="White">
                                                            <MenuItem.Icon>
                                                                <ui:SymbolIcon Symbol="Open24"
                                                                               Foreground="#00f2ff" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="Переименовать"
                                                                  Click="MenuItem_Rename_Click"
                                                                  Foreground="White">
                                                            <MenuItem.Icon>
                                                                <ui:SymbolIcon Symbol="Rename24"
                                                                               Foreground="#ffaa00" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <Separator Background="#2a2d3d" />
                                                        <MenuItem Header="Удалить"
                                                                  Click="MenuItem_Delete_Click"
                                                                  Foreground="#ff4444">
                                                            <MenuItem.Icon>
                                                                <ui:SymbolIcon Symbol="Delete24"
                                                                               Foreground="#ff4444" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="{Binding Icon}"
                                                                   Filled="True"
                                                                   Foreground="{Binding IconColor}"
                                                                   FontSize="18"
                                                                   Margin="0,0,12,0" />
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="13"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Inter, Segoe UI" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>

                                    <ListView.ContextMenu>
                                        <ContextMenu Background="#1c1e27"
                                                     Foreground="White"
                                                     BorderBrush="#2a2d3d">
                                            <MenuItem Header="Создать папку"
                                                      Click="MenuItem_CreateFolder_Click"
                                                      Foreground="White">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="FolderAdd24"
                                                                   Foreground="#ffb86c" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Создать файл"
                                                      Click="MenuItem_CreateFile_Click"
                                                      Foreground="White">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="DocumentAdd24"
                                                                   Foreground="#00f2ff" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                </ListView>
                            </Grid>
                        </TabItem>

                        <TabItem ToolTip="Сниппеты и Избранное">
                            <TabItem.Header>
                                <ui:SymbolIcon Symbol="Bookmark24"
                                               FontSize="20"
                                               Foreground="#bd93f9" />
                            </TabItem.Header>
                            <Grid Margin="0,10,0,0">
                                <TextBlock Text="Сниппеты появятся в следующем обновлении"
                                           Foreground="#a0aabf"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Padding="20" />
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="16"
                    ClipToBounds="True"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1">
                <Grid>
                    <Border Background="#0b0f19" />
                    <Border>
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="0,0"
                                                 Center="0,0"
                                                 RadiusX="1"
                                                 RadiusY="1">
                                <GradientStop Color="#CC1A2364"
                                              Offset="0" />
                                <GradientStop Color="#001A2364"
                                              Offset="0.8" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border>
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="1,1"
                                                 Center="1,1"
                                                 RadiusX="1"
                                                 RadiusY="1">
                                <GradientStop Color="#B30F3C23"
                                              Offset="0" />
                                <GradientStop Color="#000F3C23"
                                              Offset="0.8" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <wv2:WebView2 Grid.Row="0"
                                      x:Name="TerminalWebView"
                                      DefaultBackgroundColor="Transparent"
                                      Margin="0" />

                        <Border Grid.Row="1"
                                Background="Transparent"
                                Padding="16,0,16,16">

                            <Border BorderBrush="#14FFFFFF"
                                    BorderThickness="1"
                                    Background="#08FFFFFF"
                                    CornerRadius="24"
                                    Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ui:SymbolIcon Grid.Column="0"
                                                   Symbol="Star24"
                                                   Foreground="#5c6173"
                                                   FontSize="20"
                                                   VerticalAlignment="Top"
                                                   Margin="12,10,8,0" />

                                    <ui:TextBox x:Name="CommandTextBox"
                                                Grid.Column="1"
                                                Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                                                Background="Transparent"
                                                Foreground="#39ff14"
                                                BorderThickness="0"
                                                FontSize="14"
                                                FontFamily="Consolas"
                                                Padding="0,10,0,10"
                                                PlaceholderText="Введите команду и нажмите Enter..."
                                                TextWrapping="Wrap"
                                                AcceptsReturn="True"
                                                MinHeight="40"
                                                MaxHeight="120"
                                                VerticalScrollBarVisibility="Auto"
                                                VerticalContentAlignment="Top"
                                                PreviewKeyDown="CommandTextBox_PreviewKeyDown"
                                                CaretBrush="#39ff14" />

                                    <ui:Button Grid.Column="2"
                                               Click="SendCommand_Click"
                                               BorderThickness="0"
                                               Padding="0"
                                               Width="36"
                                               Height="36"
                                               VerticalAlignment="Bottom"
                                               Margin="8,2,2,2"
                                               Background="#2962ff"
                                               Cursor="Hand">
                                        <ui:Button.Template>
                                            <ControlTemplate TargetType="ui:Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="18">
                                                    <ui:SymbolIcon Symbol="Send24"
                                                                   Foreground="White"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Margin="2,2,0,0" />
                                                </Border>
                                            </ControlTemplate>
                                        </ui:Button.Template>
                                    </ui:Button>
                                </Grid>
                            </Border>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <ui:SnackbarPresenter x:Name="TerminalSnackbarPresenter"
                              Grid.RowSpan="2"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,20,40" />

        <Popup x:Name="CopyPopup"
               Placement="Mouse"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="#1A1C23"
                    BorderBrush="#3300ff88"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Margin="10">
                <Border.Effect>
                    <DropShadowEffect Color="#00ff88"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.3" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Checkmark24"
                                   Foreground="#00ff88"
                                   FontSize="14"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                    <TextBlock Text="скопировано в буфер обмена"
                               Foreground="#00ff88"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</ui:FluentWindow>