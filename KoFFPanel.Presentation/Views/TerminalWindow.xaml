<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.TerminalWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding WindowTitle}"
                 Height="750"
                 Width="1200"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#13151b"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding WindowTitle}"
                     Background="#13151b"
                     Foreground="White"
                     Padding="10,5" />

        <Border Grid.Row="1"
                Background="#1c1e27"
                BorderBrush="#2a2d3d"
                BorderThickness="0,1,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <Border Background="#13151b"
                            CornerRadius="6"
                            Padding="8"
                            Margin="0,0,15,0">
                        <ui:SymbolIcon Symbol="Desktop24"
                                       Foreground="#8be9fd"
                                       FontSize="24" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ТЕРМИНАЛ"
                                   Foreground="#50fa7b"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding ConnectionInfo}"
                                   Foreground="#6272a4"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Globe24"
                                   Foreground="#50fa7b"
                                   FontSize="16"
                                   Margin="0,0,5,0" />
                    <TextBlock Text="{Binding PingMs, StringFormat='{}{0} ms'}"
                               Foreground="#50fa7b"
                               FontSize="13"
                               FontWeight="Bold"
                               Margin="0,0,20,0" />

                    <ui:SymbolIcon Symbol="Laptop24"
                                   Foreground="#a0aabf"
                                   FontSize="16"
                                   Margin="0,0,5,0" />
                    <TextBlock Text="{Binding CpuUsage, StringFormat='CPU: {0}%'}"
                               Foreground="#a0aabf"
                               FontSize="13"
                               Margin="0,0,15,0" />

                    <ui:SymbolIcon Symbol="Server24"
                                   Foreground="#bd93f9"
                                   FontSize="16"
                                   Margin="0,0,5,0" />
                    <TextBlock Text="{Binding RamUsage, StringFormat='RAM: {0}%'}"
                               Foreground="#bd93f9"
                               FontSize="13"
                               Margin="0,0,15,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Background="#1c1e27">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="20,15"
                        BorderBrush="#2a2d3d"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Folder24"
                                       Foreground="#ffb86c"
                                       FontSize="18"
                                       Margin="0,0,10,0" />
                        <TextBlock Text="{Binding CurrentDirectory}"
                                   Foreground="#50fa7b"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding Files}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="10">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding"
                                    Value="10,8" />
                            <Setter Property="Margin"
                                    Value="0,2" />
                            <Setter Property="Cursor"
                                    Value="Hand" />
                            <EventSetter Event="MouseDoubleClick"
                                         Handler="ExplorerItem_DoubleClick" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border CornerRadius="6"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="#282a36" />
                                            </Trigger>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="#3e4152" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="{Binding Icon}"
                                               Foreground="{Binding IconColor}"
                                               FontSize="18"
                                               Margin="0,0,15,0" />
                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Border Grid.Column="1"
                    Background="#2a2d3d" />

            <Grid Grid.Column="2"
                  Background="#13151b">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <wv2:WebView2 x:Name="TerminalWebView"
                              Grid.Row="0"
                              DefaultBackgroundColor="Transparent" />

                <Border Grid.Row="1"
                        Background="#1c1e27"
                        Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#282a36"
                                CornerRadius="25,0,0,25"
                                Padding="15,0,10,0">
                            <ui:SymbolIcon Symbol="Star24"
                                           Foreground="#a0aabf"
                                           FontSize="20"
                                           VerticalAlignment="Center" />
                        </Border>

                        <ui:TextBox x:Name="CommandTextBox"
                                    Grid.Column="1"
                                    Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                                    Background="#282a36"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="15"
                                    Padding="10,15"
                                    PlaceholderText="Введите команду и нажмите Enter..."
                                    VerticalContentAlignment="Center"
                                    KeyDown="CommandTextBox_KeyDown"
                                    ClearButtonEnabled="False" />

                        <Button Grid.Column="2"
                                Click="SendCommand_Click"
                                Background="#0078D4"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="20,0"
                                Cursor="Hand"
                                HorizontalAlignment="Right">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="0,25,25,0">
                                        <ui:SymbolIcon Symbol="Send24"
                                                       Foreground="White"
                                                       FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>