<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.TerminalWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding WindowTitle}"
                 Height="700"
                 Width="1100"
                 MinHeight="500"
                 MinWidth="850"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.Resources>
            <Style TargetType="ui:Snackbar">
                <Setter Property="Background"
                        Value="#1A1C23" />
                <Setter Property="Foreground"
                        Value="#00ff88" />
                <Setter Property="BorderBrush"
                        Value="#3300ff88" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="Padding"
                        Value="16,12" />
                <Setter Property="Margin"
                        Value="0,0,0,20" />
                <Setter Property="MaxWidth"
                        Value="400" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#08FFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <ui:TitleBar Title="{Binding WindowTitle}"
                         Background="Transparent"
                         Foreground="White"
                         Padding="12,8">
                <ui:TitleBar.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="#00ff88"
                                     Margin="0,0,10,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00ff88"
                                                      BlurRadius="8"
                                                      ShadowDepth="0" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="{Binding ConnectionInfo}"
                                       Foreground="#a0aabf"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter, Segoe UI" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="100,0,20,0"
                                    Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:SymbolIcon Symbol="Pulse24"
                                           Foreground="#39ff14"
                                           FontSize="18"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PingMs, StringFormat='{}{0} ms'}"
                                       Foreground="#39ff14"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,20,0"
                                       VerticalAlignment="Center" />

                            <ui:SymbolIcon Symbol="DeveloperBoard24"
                                           Foreground="#2962ff"
                                           FontSize="18"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CpuUsage, StringFormat='CPU: {0}%'}"
                                       Foreground="#a0aabf"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,20,0"
                                       VerticalAlignment="Center" />

                            <ui:SymbolIcon Symbol="Board24"
                                           Foreground="#b026ff"
                                           FontSize="18"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RamUsage, StringFormat='RAM: {0}%'}"
                                       Foreground="#a0aabf"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,20,0"
                                       VerticalAlignment="Center" />

                            <ui:SymbolIcon Symbol="Database24"
                                           Foreground="#00e676"
                                           FontSize="18"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SsdUsage, StringFormat='SSD: {0}%'}"
                                       Foreground="#a0aabf"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </ui:TitleBar.Header>
            </ui:TitleBar>
        </Border>

        <Grid Grid.Row="1"
              Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"
                                  MinWidth="250"
                                  MaxWidth="500" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#08FFFFFF"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem"
                                   BasedOn="{StaticResource {x:Type TabItem}}">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Padding"
                                        Value="12,8" />
                                <Setter Property="Cursor"
                                        Value="Hand" />
                            </Style>
                        </TabControl.Resources>

                        <TabItem ToolTip="SFTP Проводник">
                            <TabItem.Header>
                                <Grid Width="36"
                                      Height="36"
                                      Margin="0,0,0,8">
                                    <Ellipse Width="26"
                                             Height="26"
                                             Fill="#ffaa00"
                                             Opacity="0.15"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="15"
                                                              ShadowDepth="0"
                                                              Color="#ffaa00" />
                                        </Ellipse.Effect>
                                    </Ellipse>

                                    <ui:SymbolIcon Symbol="Folder24"
                                                   Filled="True"
                                                   Foreground="#ffca28"
                                                   FontSize="28"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />

                                    <Border Background="#1c1e27"
                                            CornerRadius="8"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,-2,-2"
                                            Padding="3"
                                            BorderBrush="#2a2d3d"
                                            BorderThickness="1">
                                        <ui:SymbolIcon Symbol="Search16"
                                                       Foreground="#00f2ff"
                                                       FontSize="12"
                                                       FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </TabItem.Header>
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="Transparent"
                                        Padding="16,8">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="FolderOpen24"
                                                       Filled="True"
                                                       Foreground="#ffaa00"
                                                       Margin="0,0,10,0"
                                                       FontSize="18" />
                                        <TextBlock Text="{Binding CurrentDirectory}"
                                                   Foreground="#39ff14"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Consolas"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Cursor="Hand"
                                                   ToolTip="Двойной клик - Копировать путь"
                                                   MouseLeftButtonDown="CurrentDirectory_MouseDoubleClick" />
                                    </StackPanel>
                                </Border>

                                <ListView Grid.Row="1"
                                          ItemsSource="{Binding Files}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Margin="0,4,0,0">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding"
                                                    Value="0" />
                                            <Setter Property="Cursor"
                                                    Value="Hand" />
                                            <Setter Property="HorizontalContentAlignment"
                                                    Value="Stretch" />
                                            <EventSetter Event="MouseDoubleClick"
                                                         Handler="ExplorerItem_DoubleClick" />
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent"
                                                    Padding="16,6">
                                                <Border.ContextMenu>
                                                    <ContextMenu Background="#1c1e27"
                                                                 Foreground="White"
                                                                 BorderBrush="#2a2d3d">
                                                        <MenuItem Header="Открыть"
                                                                  Click="MenuItem_Open_Click"
                                                                  Foreground="White">
                                                            <MenuItem.Icon>
                                                                <ui:SymbolIcon Symbol="Open24"
                                                                               Foreground="#00f2ff" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="Переименовать"
                                                                  Click="MenuItem_Rename_Click"
                                                                  Foreground="White">
                                                            <MenuItem.Icon>
                                                                <ui:SymbolIcon Symbol="Rename24"
                                                                               Foreground="#ffaa00" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <Separator Background="#2a2d3d" />
                                                        <MenuItem Header="Удалить"
                                                                  Click="MenuItem_Delete_Click"
                                                                  Foreground="#ff4444">
                                                            <MenuItem.Icon>
                                                                <ui:SymbolIcon Symbol="Delete24"
                                                                               Foreground="#ff4444" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="{Binding Icon}"
                                                                   Filled="True"
                                                                   Foreground="{Binding IconColor}"
                                                                   FontSize="18"
                                                                   Margin="0,0,12,0" />
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="13"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Inter, Segoe UI" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>

                                    <ListView.ContextMenu>
                                        <ContextMenu Background="#1c1e27"
                                                     Foreground="White"
                                                     BorderBrush="#2a2d3d">
                                            <MenuItem Header="Создать папку"
                                                      Click="MenuItem_CreateFolder_Click"
                                                      Foreground="White">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="FolderAdd24"
                                                                   Foreground="#ffb86c" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Создать файл"
                                                      Click="MenuItem_CreateFile_Click"
                                                      Foreground="White">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="DocumentAdd24"
                                                                   Foreground="#00f2ff" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                </ListView>
                            </Grid>
                        </TabItem>

                        <TabItem ToolTip="Сниппеты и Избранное">
                            <TabItem.Header>
                                <Grid Width="36"
                                      Height="36"
                                      Margin="0,0,0,8">
                                    <Ellipse Width="26"
                                             Height="26"
                                             Fill="#bd93f9"
                                             Opacity="0.15"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="15"
                                                              ShadowDepth="0"
                                                              Color="#bd93f9" />
                                        </Ellipse.Effect>
                                    </Ellipse>

                                    <ui:SymbolIcon Symbol="Document24"
                                                   Filled="True"
                                                   Foreground="#7000ff"
                                                   FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="-12,6,0,0"
                                                   RenderTransformOrigin="0.5,0.5">
                                        <ui:SymbolIcon.RenderTransform>
                                            <RotateTransform Angle="-20" />
                                        </ui:SymbolIcon.RenderTransform>
                                    </ui:SymbolIcon>

                                    <ui:SymbolIcon Symbol="Document24"
                                                   Filled="True"
                                                   Foreground="#2962ff"
                                                   FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="12,6,0,0"
                                                   RenderTransformOrigin="0.5,0.5">
                                        <ui:SymbolIcon.RenderTransform>
                                            <RotateTransform Angle="20" />
                                        </ui:SymbolIcon.RenderTransform>
                                    </ui:SymbolIcon>

                                    <Grid HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0,-4,0,0">
                                        <ui:SymbolIcon Symbol="Document24"
                                                       Filled="True"
                                                       Foreground="#bd93f9"
                                                       FontSize="26" />
                                        <ui:SymbolIcon Symbol="Code20"
                                                       Foreground="#ffffff"
                                                       FontSize="14"
                                                       Margin="0,4,0,0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </TabItem.Header>
                            <Grid Margin="0,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="#1A000000"
                                        BorderBrush="#1AFFFFFF"
                                        BorderThickness="0,0,0,1">
                                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  PreviewMouseWheel="TabsScrollViewer_PreviewMouseWheel">
                                        <StackPanel Orientation="Horizontal">
                                            <ListBox ItemsSource="{Binding SnippetCategories}"
                                                     SelectedItem="{Binding SelectedSnippetCategory}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ListBox.ItemsPanel>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border x:Name="Bd"
                                                                            Padding="12,8"
                                                                            Background="Transparent"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="0,0,0,2"
                                                                            Cursor="Hand">
                                                                        <Border.ContextMenu>
                                                                            <ContextMenu Background="#1c1e27"
                                                                                         Foreground="White"
                                                                                         BorderBrush="#2a2d3d">
                                                                                <MenuItem Header="Переименовать"
                                                                                          Click="Category_Rename_Click"
                                                                                          Foreground="White">
                                                                                    <MenuItem.Icon>
                                                                                        <ui:SymbolIcon Symbol="Rename24"
                                                                                                       Foreground="#ffaa00" />
                                                                                    </MenuItem.Icon>
                                                                                </MenuItem>
                                                                                <Separator Background="#2a2d3d" />
                                                                                <MenuItem Header="Удалить"
                                                                                          Click="Category_Delete_Click"
                                                                                          Foreground="#ff4444">
                                                                                    <MenuItem.Icon>
                                                                                        <ui:SymbolIcon Symbol="Delete24"
                                                                                                       Foreground="#ff4444" />
                                                                                    </MenuItem.Icon>
                                                                                </MenuItem>
                                                                            </ContextMenu>
                                                                        </Border.ContextMenu>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="#a0aabf"
                                                                                   FontSize="13"
                                                                                   FontWeight="Bold" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsSelected"
                                                                                 Value="True">
                                                                            <Setter TargetName="Bd"
                                                                                    Property="BorderBrush"
                                                                                    Value="#00f2ff" />
                                                                            <Setter TargetName="Bd"
                                                                                    Property="Background"
                                                                                    Value="#0DFFFFFF" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                            <Button Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="#a0aabf"
                                                    FontSize="18"
                                                    Padding="8,4"
                                                    Click="AddSnippetCategory_Click"
                                                    ToolTip="Добавить категорию">
                                                <ui:SymbolIcon Symbol="Add24" />
                                            </Button>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="#0A000000"
                                        BorderBrush="#1AFFFFFF"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,6">
                                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  PreviewMouseWheel="TabsScrollViewer_PreviewMouseWheel">
                                        <StackPanel Orientation="Horizontal">
                                            <ListBox ItemsSource="{Binding SelectedSnippetCategory.SubCategories}"
                                                     SelectedItem="{Binding SelectedSnippetSubCategory}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ListBox.ItemsPanel>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border x:Name="Bd"
                                                                            Padding="10,4"
                                                                            Margin="0,0,6,0"
                                                                            Background="#0DFFFFFF"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="1"
                                                                            CornerRadius="12"
                                                                            Cursor="Hand">
                                                                        <Border.ContextMenu>
                                                                            <ContextMenu Background="#1c1e27"
                                                                                         Foreground="White"
                                                                                         BorderBrush="#2a2d3d">
                                                                                <MenuItem Header="Переименовать"
                                                                                          Click="SubCategory_Rename_Click"
                                                                                          Foreground="White">
                                                                                    <MenuItem.Icon>
                                                                                        <ui:SymbolIcon Symbol="Rename24"
                                                                                                       Foreground="#ffaa00" />
                                                                                    </MenuItem.Icon>
                                                                                </MenuItem>
                                                                                <Separator Background="#2a2d3d" />
                                                                                <MenuItem Header="Удалить"
                                                                                          Click="SubCategory_Delete_Click"
                                                                                          Foreground="#ff4444">
                                                                                    <MenuItem.Icon>
                                                                                        <ui:SymbolIcon Symbol="Delete24"
                                                                                                       Foreground="#ff4444" />
                                                                                    </MenuItem.Icon>
                                                                                </MenuItem>
                                                                            </ContextMenu>
                                                                        </Border.ContextMenu>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="#a0aabf"
                                                                                   FontSize="11" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsSelected"
                                                                                 Value="True">
                                                                            <Setter TargetName="Bd"
                                                                                    Property="Background"
                                                                                    Value="#1A00f2ff" />
                                                                            <Setter TargetName="Bd"
                                                                                    Property="BorderBrush"
                                                                                    Value="#4D00f2ff" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                            <Button Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="#a0aabf"
                                                    Padding="4"
                                                    Click="AddSnippetSubCategory_Click"
                                                    ToolTip="Добавить подкатегорию">
                                                <ui:SymbolIcon Symbol="Add16" />
                                            </Button>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <ListView Grid.Row="2"
                                          ItemsSource="{Binding SelectedSnippetSubCategory.Snippets}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="8"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding"
                                                    Value="0" />
                                            <Setter Property="Margin"
                                                    Value="0,0,0,8" />
                                            <Setter Property="HorizontalContentAlignment"
                                                    Value="Stretch" />
                                            <Setter Property="Background"
                                                    Value="Transparent" />
                                            <Setter Property="BorderThickness"
                                                    Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <Border x:Name="CardBorder"
                                                                Background="#33000000"
                                                                BorderBrush="#1AFFFFFF"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="12"
                                                                Cursor="Hand">
                                                            <Border.InputBindings>
                                                                <MouseBinding Gesture="LeftClick"
                                                                              Command="{Binding DataContext.InsertSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Border.InputBindings>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid Grid.Row="0"
                                                                      Margin="0,0,0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Description}"
                                                                               Foreground="#5c6173"
                                                                               FontSize="11"
                                                                               FontWeight="Bold" />
                                                                    <Button x:Name="DelBtn"
                                                                            Grid.Column="1"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Padding="0"
                                                                            Opacity="0"
                                                                            ToolTip="Удалить сниппет"
                                                                            Command="{Binding DataContext.DeleteSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding}">
                                                                        <ui:SymbolIcon Symbol="Delete20"
                                                                                       Foreground="#ff4444"
                                                                                       Opacity="0.8" />
                                                                    </Button>
                                                                </Grid>
                                                                <TextBlock Grid.Row="1"
                                                                           Text="{Binding Command}"
                                                                           Foreground="#39ff14"
                                                                           FontFamily="Consolas"
                                                                           FontSize="13"
                                                                           TextWrapping="Wrap" />
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver"
                                                                     Value="True">
                                                                <Setter TargetName="CardBorder"
                                                                        Property="BorderBrush"
                                                                        Value="#4D00f2ff" />
                                                                <Setter TargetName="CardBorder"
                                                                        Property="Background"
                                                                        Value="#0A00f2ff" />
                                                                <Setter TargetName="DelBtn"
                                                                        Property="Opacity"
                                                                        Value="1" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                </ListView>

                                <Border Grid.Row="3"
                                        Background="#26000000"
                                        BorderBrush="#1AFFFFFF"
                                        BorderThickness="0,1,0,0"
                                        Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ui:TextBox x:Name="NewSnippetDesc"
                                                    Grid.Column="0"
                                                    Margin="0,0,6,0"
                                                    Background="#0DFFFFFF"
                                                    BorderBrush="#1AFFFFFF"
                                                    Foreground="White"
                                                    PlaceholderText="Описание"
                                                    FontSize="12" />
                                        <ui:TextBox x:Name="NewSnippetCmd"
                                                    Grid.Column="1"
                                                    Margin="0,0,6,0"
                                                    Background="#0DFFFFFF"
                                                    BorderBrush="#1AFFFFFF"
                                                    Foreground="#39ff14"
                                                    FontFamily="Consolas"
                                                    PlaceholderText="Команда"
                                                    FontSize="12"
                                                    KeyDown="NewSnippetCmd_KeyDown" />
                                        <ui:Button Grid.Column="2"
                                                   Background="#2962ff"
                                                   BorderThickness="0"
                                                   Width="32"
                                                   Height="32"
                                                   Padding="0"
                                                   CornerRadius="8"
                                                   Click="AddSnippet_Click"
                                                   Cursor="Hand">
                                            <ui:SymbolIcon Symbol="Add24"
                                                           Foreground="White" />
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="16"
                    ClipToBounds="True"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1">
                <Grid>
                    <Border Background="#0b0f19" />
                    <Border>
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="0,0"
                                                 Center="0,0"
                                                 RadiusX="1"
                                                 RadiusY="1">
                                <GradientStop Color="#CC1A2364"
                                              Offset="0" />
                                <GradientStop Color="#001A2364"
                                              Offset="0.8" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border>
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="1,1"
                                                 Center="1,1"
                                                 RadiusX="1"
                                                 RadiusY="1">
                                <GradientStop Color="#B30F3C23"
                                              Offset="0" />
                                <GradientStop Color="#000F3C23"
                                              Offset="0.8" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <wv2:WebView2 Grid.Row="0"
                                      x:Name="TerminalWebView"
                                      DefaultBackgroundColor="Transparent"
                                      Margin="0" />

                        <Border Grid.Row="1"
                                Background="Transparent"
                                Padding="16,0,16,16">

                            <Border BorderBrush="#14FFFFFF"
                                    BorderThickness="1"
                                    Background="#08FFFFFF"
                                    CornerRadius="24"
                                    Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ui:SymbolIcon Grid.Column="0"
                                                   Symbol="Star24"
                                                   Foreground="#5c6173"
                                                   FontSize="20"
                                                   VerticalAlignment="Top"
                                                   Margin="12,10,8,0" />

                                    <ui:TextBox x:Name="CommandTextBox"
                                                Grid.Column="1"
                                                Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                                                Background="Transparent"
                                                Foreground="#39ff14"
                                                BorderThickness="0"
                                                FontSize="14"
                                                FontFamily="Consolas"
                                                Padding="10,10,0,10"
                                                PlaceholderText="Введите команду и нажмите Enter..."
                                                TextWrapping="Wrap"
                                                AcceptsReturn="True"
                                                MinHeight="40"
                                                MaxHeight="120"
                                                VerticalScrollBarVisibility="Auto"
                                                VerticalContentAlignment="Top"
                                                PreviewKeyDown="CommandTextBox_PreviewKeyDown"
                                                CaretBrush="#39ff14" />

                                    <ui:Button Grid.Column="2"
                                               Click="SendCommand_Click"
                                               BorderThickness="0"
                                               Padding="0"
                                               Width="36"
                                               Height="36"
                                               VerticalAlignment="Bottom"
                                               Margin="8,2,2,2"
                                               Background="#2962ff"
                                               Cursor="Hand">
                                        <ui:Button.Template>
                                            <ControlTemplate TargetType="ui:Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="18">
                                                    <ui:SymbolIcon Symbol="Send24"
                                                                   Foreground="White"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Margin="2,2,0,0" />
                                                </Border>
                                            </ControlTemplate>
                                        </ui:Button.Template>
                                    </ui:Button>
                                </Grid>
                            </Border>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <ui:SnackbarPresenter x:Name="TerminalSnackbarPresenter"
                              Grid.RowSpan="2"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,20,40" />

        <Popup x:Name="CopyPopup"
               Placement="Mouse"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="#1A1C23"
                    BorderBrush="#3300ff88"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Margin="10">
                <Border.Effect>
                    <DropShadowEffect Color="#00ff88"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.3" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Checkmark24"
                                   Foreground="#00ff88"
                                   FontSize="14"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                    <TextBlock Text="скопировано в буфер обмена"
                               Foreground="#00ff88"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</ui:FluentWindow>