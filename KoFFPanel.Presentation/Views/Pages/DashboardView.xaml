<UserControl x:Class="KoFFPanel.Presentation.Views.Pages.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:components="clr-namespace:KoFFPanel.Presentation.Views.Components"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/KoFFPanel.Presentation;component/Styles/CabinetWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0,0,0,20">

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="0,150,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility"
                                Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedServer}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility"
                                        Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:SymbolIcon Symbol="Server24"
                               Foreground="#3e4152"
                               FontSize="64"
                               Margin="0,0,0,15" />
                <TextBlock Text="У вас пока нет активных серверов"
                           Foreground="#7b8296"
                           FontSize="18"
                           Margin="0,0,0,25" />
                <ui:Button Command="{Binding AddServerCommand}"
                           Content="+ Добавить первый сервер"
                           Background="#ffcc00"
                           Foreground="#13151b"
                           BorderThickness="0"
                           Padding="20,10"
                           FontWeight="Bold"
                           FontSize="16"
                           Cursor="Hand" />
            </StackPanel>

            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedServer}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,25">

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <ComboBox ItemsSource="{Binding Servers}"
                                  SelectedItem="{Binding SelectedServer}"
                                  DisplayMemberPath="Name"
                                  Width="300"
                                  Background="Transparent"
                                  Foreground="White"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  FontSize="32"
                                  FontWeight="Bold"
                                  Padding="0,5"
                                  Margin="0,0,15,0"
                                  Cursor="Hand" />

                        <ui:Button Command="{Binding AddServerCommand}"
                                   ToolTip="Добавить новый сервер"
                                   Background="#282a36"
                                   Foreground="#50fa7b"
                                   BorderThickness="0"
                                   Padding="10"
                                   Margin="0,0,5,0"
                                   Cursor="Hand">
                            <ui:SymbolIcon Symbol="Add24"
                                           FontSize="18" />
                        </ui:Button>
                        <ui:Button Command="{Binding EditServerCommand}"
                                   CommandParameter="{Binding SelectedServer}"
                                   ToolTip="Настроить текущий сервер"
                                   Background="#282a36"
                                   Foreground="#a0aabf"
                                   BorderThickness="0"
                                   Padding="10"
                                   Margin="0,0,5,0"
                                   Cursor="Hand">
                            <ui:SymbolIcon Symbol="Edit24"
                                           FontSize="18" />
                        </ui:Button>
                        <ui:Button Command="{Binding DeleteServerCommand}"
                                   CommandParameter="{Binding SelectedServer}"
                                   ToolTip="Удалить текущий сервер"
                                   Background="#282a36"
                                   Foreground="#ff5555"
                                   BorderThickness="0"
                                   Padding="10"
                                   Cursor="Hand">
                            <ui:SymbolIcon Symbol="Delete24"
                                           FontSize="18" />
                        </ui:Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedServer.IpAddress}"
                                   Foreground="#ffcc00"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text=" • "
                                   Foreground="#7b8296"
                                   FontSize="16"
                                   Margin="5,0" />
                        <TextBlock Text="{Binding ServerStatus}"
                                   Foreground="#a0aabf"
                                   FontSize="16" />
                        <TextBlock Text="{Binding PingMs, StringFormat=' (Ping: {0} ms)'}"
                                   Foreground="#50fa7b"
                                   FontSize="16"
                                   Margin="5,0,0,0" />
                        <TextBlock Text=" • "
                                   Foreground="#3e4152"
                                   FontSize="16"
                                   Margin="10,0" />
                        <ui:SymbolIcon Symbol="Clock24"
                                       Foreground="#8be9fd"
                                       FontSize="16"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Uptime, StringFormat='Up: {0}'}"
                                   Foreground="#8be9fd"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" • "
                                   Foreground="#3e4152"
                                   FontSize="16"
                                   Margin="10,0" />
                        <ui:SymbolIcon Symbol="DataArea24"
                                       Foreground="#ff79c6"
                                       FontSize="16"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LoadAverage, StringFormat='Load: {0}'}"
                                   Foreground="#ff79c6"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#1c1e27"
                            CornerRadius="12"
                            Padding="20">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,10">
                                    <ui:SymbolIcon Symbol="Laptop24"
                                                   Foreground="#ff5555"
                                                   FontSize="16"
                                                   Margin="0,0,8,0" />
                                    <TextBlock Text="ЦП (CPU)"
                                               Foreground="#a0aabf"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                </StackPanel>
                                <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0}%'}"
                                           Foreground="White"
                                           FontSize="28"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <ui:ProgressRing Progress="{Binding CpuUsage}"
                                             Foreground="#ff5555"
                                             Background="#282a36"
                                             IsIndeterminate="False"
                                             Width="70"
                                             Height="70"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#1c1e27"
                            CornerRadius="12"
                            Padding="20">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,10">
                                    <ui:SymbolIcon Symbol="Server24"
                                                   Foreground="#ffb86c"
                                                   FontSize="16"
                                                   Margin="0,0,8,0" />
                                    <TextBlock Text="ОЗУ (RAM)"
                                               Foreground="#a0aabf"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                </StackPanel>
                                <TextBlock Text="{Binding RamUsage, StringFormat='{}{0}%'}"
                                           Foreground="White"
                                           FontSize="28"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <ui:ProgressRing Progress="{Binding RamUsage}"
                                             Foreground="#ffb86c"
                                             Background="#282a36"
                                             IsIndeterminate="False"
                                             Width="70"
                                             Height="70"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="4"
                            Background="#1c1e27"
                            CornerRadius="12"
                            Padding="20">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,10">
                                    <ui:SymbolIcon Symbol="Folder24"
                                                   Foreground="#f1fa8c"
                                                   FontSize="16"
                                                   Margin="0,0,8,0" />
                                    <TextBlock Text="Диск (SSD)"
                                               Foreground="#a0aabf"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                </StackPanel>
                                <TextBlock Text="{Binding SsdUsage, StringFormat='{}{0}%'}"
                                           Foreground="White"
                                           FontSize="28"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <ui:ProgressRing Progress="{Binding SsdUsage}"
                                             Foreground="#f1fa8c"
                                             Background="#282a36"
                                             IsIndeterminate="False"
                                             Width="70"
                                             Height="70"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#1c1e27"
                            CornerRadius="12"
                            Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="DataBarHorizontal24"
                                               Foreground="#bd93f9"
                                               FontSize="16"
                                               Margin="0,0,8,0" />
                                <TextBlock Text="Трафик сервера"
                                           Foreground="#a0aabf"
                                           FontWeight="SemiBold"
                                           FontSize="15" />
                            </StackPanel>
                            <TextBlock Text="{Binding TotalTraffic}"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding NetworkSpeed}"
                                       Foreground="#50fa7b"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#1c1e27"
                            CornerRadius="12"
                            Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="Link24"
                                               Foreground="#ff79c6"
                                               FontSize="16"
                                               Margin="0,0,8,0" />
                                <TextBlock Text="Сетевые сокеты"
                                           Foreground="#a0aabf"
                                           FontWeight="SemiBold"
                                           FontSize="15" />
                            </StackPanel>
                            <TextBlock Text="{Binding TcpConnections}"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,4,0,0">
                                <TextBlock Text="{Binding SynRecv, StringFormat='Аномалии: {0}'}"
                                           Foreground="#ffb86c"
                                           FontSize="13"
                                           Margin="0,0,10,0" />
                                <TextBlock Text="{Binding ErrorRate, StringFormat='Ошибки: {0}'}"
                                           Foreground="#ff5555"
                                           FontSize="13" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Background="#1c1e27"
                            CornerRadius="12"
                            Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="People24"
                                               Foreground="#8be9fd"
                                               FontSize="16"
                                               Margin="0,0,8,0" />
                                <TextBlock Text="Клиенты онлайн"
                                           Foreground="#a0aabf"
                                           FontWeight="SemiBold"
                                           FontSize="15" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding ActiveUsers}"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding TotalUsers, StringFormat=' / {0}'}"
                                           Foreground="#6272a4"
                                           FontSize="16"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,3"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <components:XrayCoreCardControl Grid.Column="0" />

                    <Border Grid.Column="2"
                            Background="#1c1e27"
                            CornerRadius="12"
                            Padding="20"
                            VerticalAlignment="Top">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#282a36"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,15,0">
                                <ui:SymbolIcon Symbol="ShieldTask24"
                                               Foreground="#ff5555"
                                               FontSize="24" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="0,0,15,0">
                                <TextBlock Text="Защита (DMCA Anti-Torrent)"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="0,0,0,3" />
                                <TextBlock Text="Базы GeoSite: Loyalsoldier"
                                           Foreground="#a0aabf"
                                           FontSize="13" />
                            </StackPanel>

                            <ui:Button Grid.Column="2"
                                       Command="{Binding UpdateGeoDataCommand}"
                                       ToolTip="Нажмите для загрузки свежих списков торрент-трекеров (Loyalsoldier) и применения правил блокировки P2P-трафика."
                                       Content="Обновить базы"
                                       Background="#ff5555"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="15,8"
                                       FontWeight="Bold"
                                       Cursor="Hand"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>