<UserControl x:Class="KoFFPanel.Presentation.Views.Pages.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:components="clr-namespace:KoFFPanel.Presentation.Views.Components"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/KoFFPanel.Presentation;component/Styles/CabinetWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="MetricCardStyle"
                   TargetType="Border">
                <Setter Property="Background"
                        Value="#08FFFFFF" />
                <Setter Property="BorderBrush"
                        Value="#1AFFFFFF" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="CornerRadius"
                        Value="20" />
                <Setter Property="Margin"
                        Value="12" />
                <Setter Property="Padding"
                        Value="24" />
                <Setter Property="RenderTransformOrigin"
                        Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter Property="Background"
                                Value="#1AFFFFFF" />
                        <Setter Property="BorderBrush"
                                Value="#4DFFFFFF" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform Y="-6" />
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#000000"
                                                  BlurRadius="20"
                                                  ShadowDepth="10"
                                                  Opacity="0.8"
                                                  Direction="315" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="TopActionBtnBase"
                   TargetType="ui:Button"
                   BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Background"
                        Value="#08FFFFFF" />
                <Setter Property="BorderBrush"
                        Value="#1AFFFFFF" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="Width"
                        Value="44" />
                <Setter Property="Height"
                        Value="44" />
                <Setter Property="Padding"
                        Value="0" />
                <Setter Property="Margin"
                        Value="0,0,12,0" />
                <Setter Property="Cursor"
                        Value="Hand" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="0" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#1a1a1a"
                                          BlurRadius="6"
                                          ShadowDepth="3"
                                          Opacity="0.8"
                                          Direction="315" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AddBtnStyle"
                   TargetType="ui:Button"
                   BasedOn="{StaticResource TopActionBtnBase}">
                <Setter Property="Foreground"
                        Value="#00ff88" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter Property="BorderBrush"
                                Value="#00ff88" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform Y="-3" />
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#00ff88"
                                                  BlurRadius="12"
                                                  ShadowDepth="0"
                                                  Opacity="0.8" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="EditBtnStyle"
                   TargetType="ui:Button"
                   BasedOn="{StaticResource TopActionBtnBase}">
                <Setter Property="Foreground"
                        Value="#00f2ff" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter Property="BorderBrush"
                                Value="#00f2ff" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform Y="-3" />
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#00f2ff"
                                                  BlurRadius="12"
                                                  ShadowDepth="0"
                                                  Opacity="0.8" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DeleteBtnStyle"
                   TargetType="ui:Button"
                   BasedOn="{StaticResource TopActionBtnBase}">
                <Setter Property="Foreground"
                        Value="#ff4444" />
                <Setter Property="Margin"
                        Value="0" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter Property="BorderBrush"
                                Value="#ff4444" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform Y="-3" />
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#ff4444"
                                                  BlurRadius="12"
                                                  ShadowDepth="0"
                                                  Opacity="0.8" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility"
                            Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedServer}"
                                     Value="{x:Null}">
                            <Setter Property="Visibility"
                                    Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <ui:SymbolIcon Symbol="Server24"
                           Foreground="#404040"
                           FontSize="80"
                           Margin="0,0,0,20" />
            <TextBlock Text="Сервер не выбран"
                       Foreground="#B3FFFFFF"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,30" />
            <ui:Button Command="{Binding AddServerCommand}"
                       Content="Добавить первый сервер"
                       Background="#00ff88"
                       Foreground="#0a0a0a"
                       BorderThickness="0"
                       Padding="24,12"
                       FontWeight="Bold"
                       FontSize="16"
                       Cursor="Hand">
                <ui:Button.Effect>
                    <DropShadowEffect Color="#00ff88"
                                      BlurRadius="15"
                                      ShadowDepth="0"
                                      Opacity="0.6" />
                </ui:Button.Effect>
            </ui:Button>
        </StackPanel>

        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility"
                            Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedServer}"
                                     Value="{x:Null}">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#08FFFFFF"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="28,20"
                    Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Grid ToolTip="Нажмите, чтобы сменить сервер">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedServer.Name}"
                                           FontSize="32"
                                           FontWeight="ExtraBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0"
                                                             EndPoint="1,1">
                                            <GradientStop Color="#ffffff"
                                                          Offset="0.0" />
                                            <GradientStop Color="#00f2ff"
                                                          Offset="1.0" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Text=" — "
                                           FontSize="28"
                                           Foreground="#666666"
                                           VerticalAlignment="Center"
                                           Margin="5,0" />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding Servers}"
                                      SelectedItem="{Binding SelectedServer}"
                                      DisplayMemberPath="Name"
                                      Opacity="0.02"
                                      Cursor="Hand"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
                        </Grid>

                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#ffaa00"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"
                                            Value="***.***.***.***" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=EyeToggle, Path=IsChecked}"
                                                     Value="True">
                                            <Setter Property="Text"
                                                    Value="{Binding SelectedServer.IpAddress}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ToggleButton x:Name="EyeToggle"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Margin="10,0,20,0"
                                      Cursor="Hand"
                                      IsChecked="True"
                                      ToolTip="Скрыть/Показать IP">
                            <ui:SymbolIcon Symbol="Eye24"
                                           Foreground="#B3FFFFFF"
                                           FontSize="20" />
                        </ToggleButton>

                        <Border Background="#1A00ff88"
                                BorderBrush="#4D00ff88"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="16,8"
                                ToolTip="{Binding ServerStatus}">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="#00ff88"
                                         Margin="0,0,8,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#00ff88"
                                                          BlurRadius="6"
                                                          ShadowDepth="0" />
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="Active"
                                           Foreground="#00ff88"
                                           FontWeight="Bold"
                                           FontSize="14" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:Button Command="{Binding AddServerCommand}"
                                   ToolTip="Добавить сервер"
                                   Style="{StaticResource AddBtnStyle}">
                            <ui:SymbolIcon Symbol="Add24"
                                           FontSize="20" />
                        </ui:Button>
                        <ui:Button Command="{Binding EditServerCommand}"
                                   CommandParameter="{Binding SelectedServer}"
                                   ToolTip="Настроить"
                                   Style="{StaticResource EditBtnStyle}">
                            <ui:SymbolIcon Symbol="Edit24"
                                           FontSize="20" />
                        </ui:Button>
                        <ui:Button Command="{Binding DeleteServerCommand}"
                                   CommandParameter="{Binding SelectedServer}"
                                   ToolTip="Удалить"
                                   Style="{StaticResource DeleteBtnStyle}">
                            <ui:SymbolIcon Symbol="Delete24"
                                           FontSize="20" />
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <components:XrayCoreCardControl Grid.Column="0" />

                <UniformGrid Grid.Column="2"
                             Columns="3"
                             Rows="3">

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Laptop24"
                                                   Foreground="#00f2ff"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="ЦП (CPU)"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0}%'}"
                                           Foreground="#ffffff"
                                           FontSize="42"
                                           FontWeight="Bold" />
                            </Viewbox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Server24"
                                                   Foreground="#ffaa00"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="ОЗУ (RAM)"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <TextBlock Text="{Binding RamUsage, StringFormat='{}{0}%'}"
                                           Foreground="#ffffff"
                                           FontSize="42"
                                           FontWeight="Bold" />
                            </Viewbox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Folder24"
                                                   Foreground="#ff00aa"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="Диск (SSD)"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <TextBlock Text="{Binding SsdUsage, StringFormat='{}{0}%'}"
                                           Foreground="#ffffff"
                                           FontSize="42"
                                           FontWeight="Bold" />
                            </Viewbox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Globe24"
                                                   Foreground="#00ff88"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="Ping"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding PingMs}"
                                               Foreground="#ffffff"
                                               FontSize="42"
                                               FontWeight="Bold" />
                                    <TextBlock Text=" ms"
                                               Foreground="#B3FFFFFF"
                                               FontSize="22"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,0,8"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Viewbox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="DataArea24"
                                                   Foreground="#7000ff"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="Load Average"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <TextBlock Text="{Binding LoadAverage}"
                                           Foreground="#ffffff"
                                           FontSize="42"
                                           FontWeight="Bold" />
                            </Viewbox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Clock24"
                                                   Foreground="#00f2ff"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="Аптайм"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Uptime}"
                                           Foreground="#ffffff"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0" />
                            </Viewbox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="DataBarHorizontal24"
                                                   Foreground="#7000ff"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="Трафик"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <TextBlock Text="{Binding TotalTraffic}"
                                           Foreground="#ffffff"
                                           FontSize="42"
                                           FontWeight="Bold" />
                            </Viewbox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Link24"
                                                   Foreground="#ffaa00"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="Сокеты"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <TextBlock Text="{Binding TcpConnections}"
                                           Foreground="#ffffff"
                                           FontSize="42"
                                           FontWeight="Bold" />
                            </Viewbox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="People24"
                                                   Foreground="#00ff88"
                                                   FontSize="20"
                                                   Margin="0,0,10,0" />
                                    <TextBlock Text="Клиенты"
                                               Foreground="#B3FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                </StackPanel>
                            </Viewbox>
                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding ActiveUsers}"
                                               Foreground="#ffffff"
                                               FontSize="42"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding TotalUsers, StringFormat=' / {0}'}"
                                               Foreground="#B3FFFFFF"
                                               FontSize="22"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,0,8"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Viewbox>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>