<UserControl x:Class="KoFFPanel.Presentation.Views.Pages.BotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/KoFFPanel.Presentation;component/Styles/CabinetWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="MetricCardStyle"
                   TargetType="Border">
                <Setter Property="Background"
                        Value="#08FFFFFF" />
                <Setter Property="BorderBrush"
                        Value="#1AFFFFFF" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="CornerRadius"
                        Value="20" />
                <Setter Property="Margin"
                        Value="12" />
                <Setter Property="Padding"
                        Value="24" />
                <Setter Property="RenderTransformOrigin"
                        Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter Property="Background"
                                Value="#1AFFFFFF" />
                        <Setter Property="BorderBrush"
                                Value="#4DFFFFFF" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform Y="-6" />
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#000000"
                                                  BlurRadius="20"
                                                  ShadowDepth="10"
                                                  Opacity="0.8"
                                                  Direction="315" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#08FFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="1"
                CornerRadius="20"
                Padding="20,15"
                Margin="24,12,24,12">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Bot24"
                                   Foreground="#00f2ff"
                                   FontSize="24"
                                   Margin="0,0,15,0" />
                    <ui:TextBox Text="{Binding BotIpAddress}"
                                PlaceholderText="IP Бота"
                                Width="130"
                                Margin="0,0,10,0"
                                ToolTip="Адрес сервера бота" />
                    <ui:TextBox Text="{Binding BotPort}"
                                PlaceholderText="Порт"
                                Width="70"
                                Margin="0,0,10,0"
                                ToolTip="API Порт (5000)" />
                    <ui:PasswordBox Password="{Binding ApiSecret, Mode=TwoWay}"
                                    PlaceholderText="API Secret"
                                    Width="150"
                                    Margin="0,0,15,0"
                                    ToolTip="Секретный ключ" />
                    <ui:Button Command="{Binding CheckBotStatusCommand}"
                               ToolTip="Проверить соединение"
                               Padding="12,8">
                        <ui:SymbolIcon Symbol="ShieldCheckmark24"
                                       Foreground="#00ff88" />
                    </ui:Button>

                    <TextBlock Text="|"
                               Foreground="#33FFFFFF"
                               FontSize="20"
                               Margin="15,0"
                               VerticalAlignment="Center" />

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                ToolTip="Текущий статус API">
                        <Ellipse Width="8"
                                 Height="8"
                                 Margin="0,0,10,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill"
                                            Value="#ff4444" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBotOnline}"
                                                     Value="True">
                                            <Setter Property="Fill"
                                                    Value="#00ff88" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding BotStatus}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="14" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="Авто-синхронизация"
                               Foreground="#B3FFFFFF"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ui:ToggleSwitch IsChecked="{Binding IsAutoSyncEnabled}"
                                     ToolTip="Фоновое обновление очереди и статусов" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource MetricCardStyle}">
                <Grid>
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="Telegram Bot"
                                   Foreground="#00f2ff"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Центр Управления"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="ExtraBold"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="Автономный сервис приема заказов и распределения конфигураций VPN."
                                   Foreground="#B3FFFFFF"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="20" />

                        <Border Background="#0AFFFFFF"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,24,0,0">
                            <StackPanel>
                                <ui:SymbolIcon Symbol="Info24"
                                               Foreground="#bd93f9"
                                               HorizontalAlignment="Left"
                                               Margin="0,0,0,8" />
                                <TextBlock Text="Бот работает автономно. Все операции происходят через защищенную очередь без прямого доступа к SSH сервера."
                                           Foreground="#80FFFFFF"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           FontStyle="Italic" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Grid.Column="1"
                         Columns="2"
                         Rows="2">

                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,15">
                                <ui:SymbolIcon Symbol="PeopleCommunity24"
                                               Foreground="#00ff88"
                                               FontSize="20"
                                               Margin="0,0,10,0" />
                                <TextBlock Text="Клиенты в Боте"
                                           Foreground="#B3FFFFFF"
                                           FontWeight="SemiBold"
                                           FontSize="16" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding TotalBotUsers}"
                                           Foreground="White"
                                           FontSize="48"
                                           FontWeight="Bold"
                                           Margin="0,0,10,0" />
                                <TextBlock Text="клиентов&#x0a;в базе"
                                           Foreground="#B3FFFFFF"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding LastNightlySyncText}"
                                       Foreground="#66FFFFFF"
                                       FontSize="12"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                        <ui:Button Command="{Binding RefreshStatsCommand}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   ToolTip="Обновить цифры сейчас">
                            <ui:SymbolIcon Symbol="ArrowCounterclockwise24"
                                           Foreground="#00ff88" />
                        </ui:Button>
                    </Grid>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,15">
                            <ui:SymbolIcon Symbol="ArrowSync24"
                                           Foreground="#ffaa00"
                                           FontSize="20"
                                           Margin="0,0,10,0" />
                            <TextBlock Text="Очередь (Pending)"
                                       Foreground="#B3FFFFFF"
                                       FontWeight="SemiBold"
                                       FontSize="16" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PendingUsersCount}"
                                       Foreground="White"
                                       FontSize="48"
                                       FontWeight="Bold" />
                            <ui:Button Command="{Binding SyncPendingUsersCommand}"
                                       Content="СИНХРОНИЗИРОВАТЬ"
                                       Margin="20,0,0,0"
                                       Padding="15,8"
                                       Background="#1Affaa00"
                                       Foreground="#ffaa00"
                                       BorderBrush="#4Dffaa00"
                                       ToolTip="Забрать новых клиентов в ядро" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,15">
                            <ui:SymbolIcon Symbol="Send24"
                                           Foreground="#00f2ff"
                                           FontSize="20"
                                           Margin="0,0,10,0" />
                            <TextBlock Text="Деплой конфигурации"
                                       Foreground="#B3FFFFFF"
                                       FontWeight="SemiBold"
                                       FontSize="16" />
                        </StackPanel>
                        <TextBlock Text="Обновление ключей (PubKey, SNI) для ссылок бота"
                                   Foreground="#80FFFFFF"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />
                        <ui:Button Command="{Binding PushTemplateToBotCommand}"
                                   Content="ОБНОВИТЬ КЛЮЧИ В БОТЕ"
                                   HorizontalAlignment="Left"
                                   Padding="20,12"
                                   Background="#1A00f2ff"
                                   Foreground="#00f2ff"
                                   BorderBrush="#4D00f2ff"
                                   ToolTip="Нажимайте при смене активного сервера" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,15">
                            <ui:SymbolIcon Symbol="ArrowAutofitHeightDotted24"
                                           Foreground="#ff00aa"
                                           FontSize="20"
                                           Margin="0,0,10,0" />
                            <TextBlock Text="Legacy База"
                                       Foreground="#B3FFFFFF"
                                       FontWeight="SemiBold"
                                       FontSize="16" />
                        </StackPanel>
                        <TextBlock Text="Перенос существующих клиентов для привязки Telegram"
                                   Foreground="#80FFFFFF"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />
                        <ui:Button Command="{Binding SyncLegacyUsersToBotCommand}"
                                   Content="ВЫГРУЗИТЬ ВСЕХ КЛИЕНТОВ"
                                   HorizontalAlignment="Left"
                                   Padding="20,12"
                                   Background="#1Aff00aa"
                                   Foreground="#ff00aa"
                                   BorderBrush="#4Dff00aa"
                                   ToolTip="Копирует всех клиентов из панели в бота" />
                    </StackPanel>
                </Border>

            </UniformGrid>
        </Grid>
    </Grid>
</UserControl>