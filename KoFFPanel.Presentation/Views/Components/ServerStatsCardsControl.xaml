<UserControl x:Class="KoFFPanel.Presentation.Views.Components.ServerStatsCardsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#1c1e27"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,10,0"
                BorderBrush="#2a2d3d"
                BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">
                    <Border Background="#282a36"
                            CornerRadius="6"
                            Padding="6"
                            Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="People24"
                                       Foreground="#8be9fd"
                                       FontSize="18" />
                    </Border>
                    <TextBlock Text="Клиенты"
                               Foreground="#a0aabf"
                               FontSize="14"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding ActiveUsers}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding TotalUsers, StringFormat=' / {0}'}"
                               Foreground="#6272a4"
                               FontSize="16"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#1c1e27"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,10,0"
                BorderBrush="#2a2d3d"
                BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,10">
                    <Border Background="#282a36"
                            CornerRadius="6"
                            Padding="6"
                            Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="DataBarHorizontal24"
                                       Foreground="#bd93f9"
                                       FontSize="18" />
                    </Border>
                    <TextBlock Text="Трафик"
                               Foreground="#a0aabf"
                               FontSize="14"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding TotalTraffic}"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding NetworkSpeed}"
                           Foreground="#50fa7b"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Background="#1c1e27"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,10,0"
                BorderBrush="#2a2d3d"
                BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">
                    <Border Background="#282a36"
                            CornerRadius="6"
                            Padding="6"
                            Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="Server24"
                                       Foreground="#ffb86c"
                                       FontSize="18" />
                    </Border>
                    <TextBlock Text="ОЗУ (RAM)"
                               Foreground="#a0aabf"
                               FontSize="14"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding RamUsage, StringFormat='{}{0}%'}"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold" />
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{Binding RamUsage}"
                             Height="4"
                             Margin="0,10,0,0"
                             Foreground="#ffb86c"
                             Background="#282a36" />
            </StackPanel>
        </Border>

        <Border Grid.Column="3"
                Background="#1c1e27"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,10,0"
                BorderBrush="#2a2d3d"
                BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">
                    <Border Background="#282a36"
                            CornerRadius="6"
                            Padding="6"
                            Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="Laptop24"
                                       Foreground="#ff5555"
                                       FontSize="18" />
                    </Border>
                    <TextBlock Text="CPU"
                               Foreground="#a0aabf"
                               FontSize="14"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0}%'}"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold" />
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{Binding CpuUsage}"
                             Height="4"
                             Margin="0,10,0,0"
                             Foreground="#ff5555"
                             Background="#282a36" />
            </StackPanel>
        </Border>

        <Border Grid.Column="4"
                Background="#1c1e27"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,10,0"
                BorderBrush="#2a2d3d"
                BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">
                    <Border Background="#282a36"
                            CornerRadius="6"
                            Padding="6"
                            Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="Folder24"
                                       Foreground="#f1fa8c"
                                       FontSize="18" />
                    </Border>
                    <TextBlock Text="Диск (SSD)"
                               Foreground="#a0aabf"
                               FontSize="14"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding SsdUsage, StringFormat='{}{0}%'}"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold" />
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{Binding SsdUsage}"
                             Height="4"
                             Margin="0,10,0,0"
                             Foreground="#f1fa8c"
                             Background="#282a36" />
            </StackPanel>
        </Border>

        <Border Grid.Column="5"
                Background="#1c1e27"
                CornerRadius="8"
                Padding="15"
                BorderBrush="#2a2d3d"
                BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">
                    <Border Background="#282a36"
                            CornerRadius="6"
                            Padding="6"
                            Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="Link24"
                                       Foreground="#ff79c6"
                                       FontSize="18" />
                    </Border>
                    <TextBlock Text="Сеть (Сокеты)"
                               Foreground="#a0aabf"
                               FontSize="14"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding TcpConnections}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White" />
                <TextBlock Text="{Binding SynRecv, StringFormat='Аномалии (SYN): {0}'}"
                           Foreground="#ffb86c"
                           Margin="0,2,0,0" />
                <TextBlock Text="{Binding ErrorRate, StringFormat='Ошибки (5м): {0}'}"
                           Foreground="#ff5555"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>