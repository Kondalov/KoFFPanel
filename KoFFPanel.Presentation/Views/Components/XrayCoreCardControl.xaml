<UserControl x:Class="KoFFPanel.Presentation.Views.Components.XrayCoreCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border Background="#1c1e27"
            CornerRadius="8"
            Padding="20"
            VerticalAlignment="Top">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,20"
                        VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Shield24"
                               Foreground="#ffcc00"
                               FontSize="20"
                               Margin="0,0,10,0" />
                <TextBlock Text="Ядро (Xray-core)"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,20">
                <TextBlock Text="Статус:"
                           Foreground="#7b8296"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center" />
                <Border Background="#282a36"
                        CornerRadius="4"
                        Padding="8,4">
                    <TextBlock Text="{Binding XrayStatus}"
                               Foreground="#50fa7b"
                               FontWeight="Bold" />
                </Border>
                <TextBlock Text="{Binding XrayProcesses, StringFormat='PID: {0}'}"
                           Foreground="#6272a4"
                           FontSize="13"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           ToolTip="Количество запущенных процессов ядра" />

                <ui:Button Command="{Binding RestartXrayCommand}"
                           Margin="10,0,0,0"
                           Padding="8,4"
                           Background="#3e4152"
                           BorderThickness="0"
                           Cursor="Hand"
                           ToolTip="Перезапустить ядро"
                           HorizontalAlignment="Right">
                    <ui:SymbolIcon Symbol="ArrowClockwise24"
                                   Foreground="White"
                                   FontSize="14" />
                </ui:Button>
            </StackPanel>

            <Grid Grid.Row="2"
                  Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Версия:"
                           Foreground="#7b8296"
                           Margin="0,0,10,8" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding XrayVersion}"
                           Foreground="White"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="ОЗУ (RAM):"
                           Foreground="#7b8296"
                           Margin="0,0,10,8" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding XrayMemory}"
                           Foreground="#8be9fd"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Аптайм:"
                           Foreground="#7b8296"
                           Margin="0,0,10,8" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding XrayUptime}"
                           Foreground="White"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Text="Конфиг:"
                           Foreground="#7b8296"
                           Margin="0,0,10,8" />
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Text="{Binding XrayConfigStatus}"
                           Foreground="#50fa7b"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="Ошибка:"
                           Foreground="#7b8296"
                           Margin="0,0,10,0" />
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding XrayLastError}"
                           Foreground="#ff5555"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding XrayLastError}" />
            </Grid>

            <ui:Button Grid.Row="3"
                       Command="{Binding GenerateRealityConfigCommand}"
                       Content="🚀 Создать VLESS-Reality"
                       Background="#bd93f9"
                       Foreground="#13151b"
                       FontWeight="Bold"
                       BorderThickness="0"
                       HorizontalAlignment="Stretch"
                       Cursor="Hand"
                       Margin="0,0,0,5" />

            <Expander Grid.Row="4"
                      Header="Логи ядра Xray"
                      Foreground="#a0aabf"
                      BorderThickness="0"
                      Background="Transparent"
                      Margin="0,10,0,0">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ui:Button Grid.Row="0"
                               Command="{Binding CopyXrayLogsCommand}"
                               Background="Transparent"
                               BorderThickness="0"
                               Padding="4"
                               Cursor="Hand"
                               ToolTip="Скопировать логи"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,5">
                        <ui:SymbolIcon Symbol="Copy24"
                                       Foreground="#a0aabf"
                                       FontSize="16" />
                    </ui:Button>

                    <Border Grid.Row="1"
                            Background="#0a0b0f"
                            CornerRadius="6"
                            Padding="10">
                        <ScrollViewer MaxHeight="250"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding XrayLogs}"
                                       Foreground="#6272a4"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Expander>
        </Grid>
    </Border>
</UserControl>