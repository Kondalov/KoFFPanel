<UserControl x:Class="KoFFPanel.Presentation.Views.Components.ClientTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/KoFFPanel.Presentation;component/Styles/CabinetWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="#1c1e27"
            CornerRadius="8"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="People24"
                                   Foreground="#8be9fd"
                                   FontSize="20"
                                   Margin="0,0,10,0" />
                    <TextBlock Text="Пользователи (Клиенты)"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold" />
                </StackPanel>
                <ui:Button HorizontalAlignment="Right"
                           Command="{Binding AddClientCommand}"
                           Content="+ Создать"
                           Background="#ffcc00"
                           Foreground="#13151b"
                           BorderThickness="0"
                           Padding="15,6"
                           FontWeight="Bold"
                           Cursor="Hand" />
            </Grid>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Clients}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      Background="Transparent"
                      RowBackground="Transparent"
                      BorderThickness="0"
                      GridLinesVisibility="None"
                      IsReadOnly="True"
                      Foreground="White"
                      CanUserResizeColumns="True"
                      ColumnHeaderStyle="{StaticResource StandardDataGridHeader}"
                      CellStyle="{StaticResource StandardDataGridCell}">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Note}"
                                        Width="150">
                        <DataGridTextColumn.Header>
                            <ui:SymbolIcon Symbol="Note24"
                                           ToolTip="Заметка"
                                           Foreground="#a0aabf" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding Email}"
                                        Width="*">
                        <DataGridTextColumn.Header>
                            <ui:SymbolIcon Symbol="Mail24"
                                           ToolTip="Email"
                                           Foreground="#a0aabf" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding LastIp}"
                                        Width="110">
                        <DataGridTextColumn.Header>
                            <ui:SymbolIcon Symbol="Location24"
                                           ToolTip="Последний IP"
                                           Foreground="#a0aabf" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding Country}"
                                        Width="80">
                        <DataGridTextColumn.Header>
                            <ui:SymbolIcon Symbol="Globe24"
                                           ToolTip="Страна"
                                           Foreground="#a0aabf" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding ActiveConnections}"
                                        Width="60">
                        <DataGridTextColumn.Header>
                            <ui:SymbolIcon Symbol="Laptop24"
                                           ToolTip="Устройства"
                                           Foreground="#a0aabf" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding TrafficUsageString}"
                                        Width="160">
                        <DataGridTextColumn.Header>
                            <ui:SymbolIcon Symbol="DataBarHorizontal24"
                                           ToolTip="Трафик"
                                           Foreground="#a0aabf" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding LastOnlineString}"
                                        Width="110">
                        <DataGridTextColumn.Header>
                            <ui:SymbolIcon Symbol="History24"
                                           ToolTip="Онлайн"
                                           Foreground="#a0aabf" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="60">
                        <DataGridTemplateColumn.Header>
                            <ui:SymbolIcon Symbol="ShieldCheckmark24"
                                           ToolTip="Антифрод"
                                           Foreground="#a0aabf" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsAntiFraudEnabled, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ToolTip="Авто-бан" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.Header>
                            <ui:SymbolIcon Symbol="Settings24"
                                           ToolTip="Действия"
                                           Foreground="#a0aabf" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <ui:Button Command="{Binding DataContext.EditClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="6"
                                               Cursor="Hand"
                                               ToolTip="Редактировать">
                                        <ui:SymbolIcon Symbol="Edit24"
                                                       Foreground="#a0aabf"
                                                       FontSize="16" />
                                    </ui:Button>
                                    <ui:Button Command="{Binding DataContext.CopyClientLinkCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="6"
                                               Cursor="Hand"
                                               ToolTip="Копировать ссылку">
                                        <ui:SymbolIcon Symbol="Link24"
                                                       Foreground="#8be9fd"
                                                       FontSize="16" />
                                    </ui:Button>
                                    <ui:Button Command="{Binding DataContext.ToggleClientAccessCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="6"
                                               Cursor="Hand"
                                               ToolTip="Бан/Разбан">
                                        <ui:SymbolIcon FontSize="16">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Symbol"
                                                            Value="Pause24" />
                                                    <Setter Property="Foreground"
                                                            Value="#ffb86c" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}"
                                                                     Value="False">
                                                            <Setter Property="Symbol"
                                                                    Value="Play24" />
                                                            <Setter Property="Foreground"
                                                                    Value="#50fa7b" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </ui:Button>
                                    <ui:Button Command="{Binding DataContext.ResetClientTrafficCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="6"
                                               Cursor="Hand"
                                               ToolTip="Сброс трафика">
                                        <ui:SymbolIcon Symbol="ArrowClockwise24"
                                                       Foreground="#ffcc00"
                                                       FontSize="16" />
                                    </ui:Button>
                                    <ui:Button Command="{Binding DataContext.DeleteClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="6"
                                               Cursor="Hand"
                                               ToolTip="Удалить">
                                        <ui:SymbolIcon Symbol="Delete24"
                                                       Foreground="#ff5555"
                                                       FontSize="16" />
                                    </ui:Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>