<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.ServerSelectionWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Выбор целевого сервера"
                 Width="500"
                 Height="550"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Выбор целевого сервера"
                     Background="Transparent"
                     Foreground="White"
                     Padding="15,5" />

        <Grid Grid.Row="1"
              Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,6">
                    <ui:SymbolIcon Symbol="Server24"
                                   Foreground="#00f2ff"
                                   FontSize="26"
                                   Margin="0,0,10,0" />
                    <TextBlock Text="КУДА УСТАНОВИТЬ?"
                               Foreground="White"
                               FontWeight="ExtraBold"
                               FontSize="22" />
                </StackPanel>
                <TextBlock Text="У вас несколько серверов. Выберите нужный."
                           Foreground="#B3FFFFFF"
                           FontSize="13"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <ListView Grid.Row="1"
                      x:Name="ServersList"
                      Background="Transparent"
                      BorderThickness="0"
                      SelectionChanged="ServersList_SelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding"
                                Value="0" />
                        <Setter Property="Margin"
                                Value="0,0,0,12" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch" />
                        <Setter Property="Cursor"
                                Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="CardBorder"
                                            Background="#08FFFFFF"
                                            BorderBrush="#1AFFFFFF"
                                            BorderThickness="2"
                                            CornerRadius="16"
                                            Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="16"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="{Binding IpAddress}"
                                                           Foreground="#a0aabf"
                                                           FontFamily="Consolas"
                                                           FontSize="13" />
                                            </StackPanel>
                                            <Border x:Name="CheckBadge"
                                                    Grid.Column="1"
                                                    Width="24"
                                                    Height="24"
                                                    Background="#00f2ff"
                                                    CornerRadius="12"
                                                    Opacity="0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="✓"
                                                           Foreground="Black"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#00f2ff"
                                                                      BlurRadius="10"
                                                                      ShadowDepth="0"
                                                                      Opacity="0.5" />
                                                </Border.Effect>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="CardBorder"
                                                    Property="Background"
                                                    Value="#14FFFFFF" />
                                            <Setter TargetName="CardBorder"
                                                    Property="BorderBrush"
                                                    Value="#33FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected"
                                                 Value="True">
                                            <Setter TargetName="CardBorder"
                                                    Property="Background"
                                                    Value="#0A00f2ff" />
                                            <Setter TargetName="CardBorder"
                                                    Property="BorderBrush"
                                                    Value="#00f2ff" />
                                            <Setter TargetName="CheckBadge"
                                                    Property="Opacity"
                                                    Value="1" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>

        <Grid Grid.Row="2"
              Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       Content="ОТМЕНА"
                       Click="Cancel_Click"
                       Background="#1AFFFFFF"
                       Foreground="#B3FFFFFF"
                       BorderThickness="0"
                       Padding="0,14"
                       HorizontalAlignment="Stretch"
                       Cursor="Hand" />
            <ui:Button Grid.Column="2"
                       x:Name="ConfirmBtn"
                       Content="ПРОДОЛЖИТЬ"
                       Click="Confirm_Click"
                       Background="#00cc6a"
                       Foreground="Black"
                       BorderThickness="0"
                       Padding="0,14"
                       HorizontalAlignment="Stretch"
                       Cursor="Hand"
                       IsEnabled="False">
                <ui:Button.Effect>
                    <DropShadowEffect Color="#00ff88"
                                      BlurRadius="15"
                                      ShadowDepth="0"
                                      Opacity="0.4" />
                </ui:Button.Effect>
            </ui:Button>
        </Grid>
    </Grid>
</ui:FluentWindow>