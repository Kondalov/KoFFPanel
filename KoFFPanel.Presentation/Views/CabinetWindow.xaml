<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.CabinetWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding Title}"
                 Height="800"
                 Width="1250"
                 MinHeight="700"
                 MinWidth="1150"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/KoFFPanel.Presentation;component/Styles/CabinetWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.8,0.2"
                                 Center="0.8,0.2"
                                 RadiusX="0.5"
                                 RadiusY="0.5">
                <GradientStop Color="#1A00f2ff"
                              Offset="0.0" />
                <GradientStop Color="#000a0a0a"
                              Offset="1.0" />
            </RadialGradientBrush>
        </Grid.Background>

        <Grid>
            <Grid.Background>
                <RadialGradientBrush GradientOrigin="0.2,0.8"
                                     Center="0.2,0.8"
                                     RadiusX="0.6"
                                     RadiusY="0.6">
                    <GradientStop Color="#1A7000ff"
                                  Offset="0.0" />
                    <GradientStop Color="#000a0a0a"
                                  Offset="1.0" />
                </RadialGradientBrush>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0"
                         Title="{Binding Title}"
                         Background="Transparent"
                         Foreground="#ffffff"
                         Padding="15,5" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="260"
                        Background="#08FFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Margin="24,0,0,24">
                    <Grid Margin="0,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#0AFFFFFF"
                                CornerRadius="16"
                                Padding="16"
                                Margin="24,0,24,24">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Server24"
                                               Foreground="#00f2ff"
                                               FontSize="26"
                                               Margin="0,0,12,0">
                                    <ui:SymbolIcon.Effect>
                                        <DropShadowEffect Color="#00f2ff"
                                                          BlurRadius="10"
                                                          ShadowDepth="0" />
                                    </ui:SymbolIcon.Effect>
                                </ui:SymbolIcon>
                                <TextBlock Text="KoFFPanel"
                                           FontSize="22"
                                           FontWeight="ExtraBold">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0"
                                                             EndPoint="1,1">
                                            <GradientStop Color="#00f2ff"
                                                          Offset="0.0" />
                                            <GradientStop Color="#7000ff"
                                                          Offset="1.0" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="1">
                            <ui:Button Command="{Binding NavigateToDashboardCommand}"
                                       HorizontalAlignment="Stretch"
                                       BorderThickness="0"
                                       Padding="18,14"
                                       Cursor="Hand"
                                       Margin="16,0,16,8">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button"
                                           BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Background"
                                                Value="Transparent" />
                                        <Setter Property="Foreground"
                                                Value="#B3FFFFFF" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}"
                                                         Value="Dashboard">
                                                <Setter Property="Background"
                                                        Value="#1A00f2ff" />
                                                <Setter Property="Foreground"
                                                        Value="#00f2ff" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Width="200">
                                    <ui:SymbolIcon Symbol="Home24"
                                                   FontSize="20"
                                                   Margin="0,0,12,0" />
                                    <TextBlock Text="Сервер"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>

                            <ui:Button Command="{Binding NavigateToClientsCommand}"
                                       HorizontalAlignment="Stretch"
                                       BorderThickness="0"
                                       Padding="18,14"
                                       Cursor="Hand"
                                       Margin="16,0,16,8">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button"
                                           BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Background"
                                                Value="Transparent" />
                                        <Setter Property="Foreground"
                                                Value="#B3FFFFFF" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}"
                                                         Value="Clients">
                                                <Setter Property="Background"
                                                        Value="#1A00f2ff" />
                                                <Setter Property="Foreground"
                                                        Value="#00f2ff" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Width="200">
                                    <ui:SymbolIcon Symbol="People24"
                                                   FontSize="20"
                                                   Margin="0,0,12,0" />
                                    <TextBlock Text="Подключения"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>

                            <ui:Button IsEnabled="False"
                                       ToolTip="В разработке"
                                       HorizontalAlignment="Stretch"
                                       Background="Transparent"
                                       Foreground="#666666"
                                       BorderThickness="0"
                                       Padding="18,14"
                                       Margin="16,0,16,8">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Width="200">
                                    <ui:SymbolIcon Symbol="Settings24"
                                                   FontSize="20"
                                                   Margin="0,0,12,0" />
                                    <TextBlock Text="Настройки"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>

                            <ui:Button Command="{Binding OpenDeployWizardCommand}"
                                       ToolTip="Первичная настройка сервера"
                                       HorizontalAlignment="Stretch"
                                       BorderThickness="0"
                                       Padding="18,14"
                                       Cursor="Hand"
                                       Margin="16,0,16,8">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button"
                                           BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Background"
                                                Value="Transparent" />
                                        <Setter Property="Foreground"
                                                Value="#B3FFFFFF" />
                                    </Style>
                                </ui:Button.Style>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Width="200">
                                    <ui:SymbolIcon Symbol="Rocket24"
                                                   FontSize="20"
                                                   Margin="0,0,12,0" />
                                    <TextBlock Text="Мастер установки"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>

                            <ui:Button Command="{Binding OpenTerminalCommand}"
                                       ToolTip="SSH Терминал"
                                       HorizontalAlignment="Stretch"
                                       BorderThickness="0"
                                       Padding="18,14"
                                       Cursor="Hand"
                                       Margin="16,0,16,8">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button"
                                           BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Background"
                                                Value="Transparent" />
                                        <Setter Property="Foreground"
                                                Value="#B3FFFFFF" />
                                    </Style>
                                </ui:Button.Style>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Width="200">
                                    <ui:SymbolIcon Symbol="Code24"
                                                   FontSize="20"
                                                   Margin="0,0,12,0" />
                                    <TextBlock Text="Терминал"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      Margin="24,0,24,24">
                    <ContentControl Content="{Binding CurrentView}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>