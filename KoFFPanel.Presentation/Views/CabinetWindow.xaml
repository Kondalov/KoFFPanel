<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.CabinetWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding Title}"
                 Height="800"
                 Width="1250"
                 MinHeight="700"
                 MinWidth="1150"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="None"
                 Background="#0a0b0f"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="DarkListViewItem"
               TargetType="ListViewItem">
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#1c1e27" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#282a36" />
                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#ffcc00" />
                                <Setter TargetName="Bd"
                                        Property="BorderThickness"
                                        Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding Title}"
                     Background="Transparent"
                     Foreground="White"
                     Padding="15,5" />

        <Grid Grid.Row="1"
              Margin="20,0,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Server24"
                                   Foreground="#7b8296"
                                   FontSize="28"
                                   Margin="0,0,15,0" />
                    <TextBlock Text="{Binding Title}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ui:Button Command="{Binding OpenDeployWizardCommand}"
                               Background="#ffcc00"
                               Foreground="#13151b"
                               BorderThickness="0"
                               Padding="15,8"
                               Cursor="Hand"
                               ToolTip="Мастер установки ядер"
                               Margin="0,0,15,0">
                        <ui:SymbolIcon Symbol="Rocket24"
                                       FontSize="20" />
                    </ui:Button>

                    <ui:Button Command="{Binding OpenTerminalCommand}"
                               Background="#282a36"
                               Foreground="White"
                               BorderThickness="1"
                               BorderBrush="#3e4152"
                               Padding="15,8"
                               Cursor="Hand"
                               ToolTip="Открыть SSH Терминал">
                        <ui:SymbolIcon Symbol="Code24"
                                       FontSize="20" />
                    </ui:Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#13151b"
                        CornerRadius="12"
                        Padding="15"
                        Margin="0,0,20,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Command="{Binding AddServerCommand}"
                                Content="+ Добавить сервер"
                                Background="#282a36"
                                Foreground="White"
                                BorderThickness="1"
                                BorderBrush="#3e4152"
                                Padding="10"
                                Margin="0,0,0,15"
                                HorizontalAlignment="Stretch"
                                Cursor="Hand"
                                FontWeight="SemiBold" />

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ListView ItemsSource="{Binding Servers}"
                                      SelectedItem="{Binding SelectedServer}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ItemContainerStyle="{StaticResource DarkListViewItem}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent"
                                                Padding="12,15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="16"
                                                               Margin="0,0,0,4"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding IpAddress}"
                                                               Foreground="#7b8296"
                                                               FontSize="13"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <ui:Button Command="{Binding DataContext.EditServerCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                               CommandParameter="{Binding}"
                                                               Background="Transparent"
                                                               BorderThickness="0"
                                                               Padding="6"
                                                               Cursor="Hand"
                                                               ToolTip="Редактировать"
                                                               Margin="0,0,5,0">
                                                        <ui:SymbolIcon Symbol="Edit24"
                                                                       Foreground="#a0aabf"
                                                                       FontSize="18" />
                                                    </ui:Button>
                                                    <ui:Button Command="{Binding DataContext.DeleteServerCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                               CommandParameter="{Binding}"
                                                               Background="Transparent"
                                                               BorderThickness="0"
                                                               Padding="6"
                                                               Cursor="Hand"
                                                               ToolTip="Удалить">
                                                        <ui:SymbolIcon Symbol="Delete24"
                                                                       Foreground="#ff5555"
                                                                       FontSize="18" />
                                                    </ui:Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="#13151b"
                        CornerRadius="12"
                        Padding="25">
                    <Grid>
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedServer}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:SymbolIcon Symbol="Play24"
                                           Foreground="#3e4152"
                                           FontSize="64"
                                           Margin="0,0,0,15" />
                            <TextBlock Text="Выберите сервер из списка слева"
                                       Foreground="#7b8296"
                                       FontSize="18" />
                        </StackPanel>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedServer}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Margin="0,0,0,25">
                                <TextBlock Text="{Binding SelectedServer.Name}"
                                           Foreground="White"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SelectedServer.IpAddress}"
                                               Foreground="#ffcc00"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text=" • "
                                               Foreground="#7b8296"
                                               FontSize="16"
                                               Margin="5,0" />
                                    <TextBlock Text="{Binding ServerStatus}"
                                               Foreground="#a0aabf"
                                               FontSize="16" />
                                    <TextBlock Text="{Binding PingMs, StringFormat=' (Ping: {0} ms)'}"
                                               Foreground="#50fa7b"
                                               FontSize="16"
                                               Margin="5,0,0,0" />
                                    <TextBlock Text=" • "
                                               Foreground="#3e4152"
                                               FontSize="16"
                                               Margin="10,0" />

                                    <ui:SymbolIcon Symbol="Clock24"
                                                   Foreground="#8be9fd"
                                                   FontSize="16"
                                                   Margin="0,0,5,0"
                                                   VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Uptime, StringFormat='Up: {0}'}"
                                               Foreground="#8be9fd"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />

                                    <TextBlock Text=" • "
                                               Foreground="#3e4152"
                                               FontSize="16"
                                               Margin="10,0" />

                                    <ui:SymbolIcon Symbol="DataArea24"
                                                   Foreground="#ff79c6"
                                                   FontSize="16"
                                                   Margin="0,0,5,0"
                                                   VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding LoadAverage, StringFormat='Load: {0}'}"
                                               Foreground="#ff79c6"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#1c1e27"
                                        CornerRadius="8"
                                        Padding="15"
                                        Margin="0,0,10,0"
                                        BorderBrush="#2a2d3d"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,15">
                                            <Border Background="#282a36"
                                                    CornerRadius="6"
                                                    Padding="6"
                                                    Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="People24"
                                                               Foreground="#8be9fd"
                                                               FontSize="18" />
                                            </Border>
                                            <TextBlock Text="Клиенты"
                                                       Foreground="#a0aabf"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding ActiveUsers}"
                                                       Foreground="White"
                                                       FontSize="26"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="{Binding TotalUsers, StringFormat=' / {0}'}"
                                                       Foreground="#6272a4"
                                                       FontSize="16"
                                                       VerticalAlignment="Bottom"
                                                       Margin="0,0,0,4"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="#1c1e27"
                                        CornerRadius="8"
                                        Padding="15"
                                        Margin="0,0,10,0"
                                        BorderBrush="#2a2d3d"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,10">
                                            <Border Background="#282a36"
                                                    CornerRadius="6"
                                                    Padding="6"
                                                    Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="DataBarHorizontal24"
                                                               Foreground="#bd93f9"
                                                               FontSize="18" />
                                            </Border>
                                            <TextBlock Text="Трафик"
                                                       Foreground="#a0aabf"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding TotalTraffic}"
                                                   Foreground="White"
                                                   FontSize="22"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding NetworkSpeed}"
                                                   Foreground="#50fa7b"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="#1c1e27"
                                        CornerRadius="8"
                                        Padding="15"
                                        Margin="0,0,10,0"
                                        BorderBrush="#2a2d3d"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,15">
                                            <Border Background="#282a36"
                                                    CornerRadius="6"
                                                    Padding="6"
                                                    Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="Server24"
                                                               Foreground="#ffb86c"
                                                               FontSize="18" />
                                            </Border>
                                            <TextBlock Text="ОЗУ (RAM)"
                                                       Foreground="#a0aabf"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding RamUsage, StringFormat='{}{0}%'}"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="Bold" />
                                        <ProgressBar Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding RamUsage}"
                                                     Height="4"
                                                     Margin="0,10,0,0"
                                                     Foreground="#ffb86c"
                                                     Background="#282a36" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3"
                                        Background="#1c1e27"
                                        CornerRadius="8"
                                        Padding="15"
                                        Margin="0,0,10,0"
                                        BorderBrush="#2a2d3d"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,15">
                                            <Border Background="#282a36"
                                                    CornerRadius="6"
                                                    Padding="6"
                                                    Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="Laptop24"
                                                               Foreground="#ff5555"
                                                               FontSize="18" />
                                            </Border>
                                            <TextBlock Text="CPU"
                                                       Foreground="#a0aabf"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0}%'}"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="Bold" />
                                        <ProgressBar Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding CpuUsage}"
                                                     Height="4"
                                                     Margin="0,10,0,0"
                                                     Foreground="#ff5555"
                                                     Background="#282a36" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4"
                                        Background="#1c1e27"
                                        CornerRadius="8"
                                        Padding="15"
                                        Margin="0,0,10,0"
                                        BorderBrush="#2a2d3d"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,15">
                                            <Border Background="#282a36"
                                                    CornerRadius="6"
                                                    Padding="6"
                                                    Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="Folder24"
                                                               Foreground="#f1fa8c"
                                                               FontSize="18" />
                                            </Border>
                                            <TextBlock Text="Диск (SSD)"
                                                       Foreground="#a0aabf"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding SsdUsage, StringFormat='{}{0}%'}"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="Bold" />
                                        <ProgressBar Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding SsdUsage}"
                                                     Height="4"
                                                     Margin="0,10,0,0"
                                                     Foreground="#f1fa8c"
                                                     Background="#282a36" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="5"
                                        Background="#1c1e27"
                                        CornerRadius="8"
                                        Padding="15"
                                        BorderBrush="#2a2d3d"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,15">
                                            <Border Background="#282a36"
                                                    CornerRadius="6"
                                                    Padding="6"
                                                    Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="Link24"
                                                               Foreground="#ff79c6"
                                                               FontSize="18" />
                                            </Border>
                                            <TextBlock Text="Сеть (Сокеты)"
                                                       Foreground="#a0aabf"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>

                                        <TextBlock Text="{Binding TcpConnections}"
                                                   FontSize="32"
                                                   FontWeight="Bold"
                                                   Foreground="White" />
                                        <TextBlock Text="{Binding SynRecv, StringFormat='Аномалии (SYN): {0}'}"
                                                   Foreground="#ffb86c"
                                                   Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding ErrorRate, StringFormat='Ошибки (5м): {0}'}"
                                                   Foreground="#ff5555"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="340" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#1c1e27"
                                        CornerRadius="8"
                                        Padding="20"
                                        Margin="0,0,20,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Margin="0,0,0,20"
                                                    VerticalAlignment="Center">
                                            <ui:SymbolIcon Symbol="Shield24"
                                                           Foreground="#ffcc00"
                                                           FontSize="20"
                                                           Margin="0,0,10,0" />
                                            <TextBlock Text="Ядро (Xray-core)"
                                                       Foreground="White"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    Margin="0,0,0,20">
                                            <TextBlock Text="Статус:"
                                                       Foreground="#7b8296"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center" />
                                            <Border Background="#282a36"
                                                    CornerRadius="4"
                                                    Padding="8,4">
                                                <TextBlock Text="{Binding XrayStatus}"
                                                           Foreground="#50fa7b"
                                                           FontWeight="Bold" />
                                            </Border>
                                            <TextBlock Text="{Binding XrayProcesses, StringFormat='PID: {0}'}"
                                                       Foreground="#6272a4"
                                                       FontSize="13"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center"
                                                       ToolTip="Количество запущенных процессов ядра" />

                                            <ui:Button Command="{Binding RestartXrayCommand}"
                                                       Margin="10,0,0,0"
                                                       Padding="8,4"
                                                       Background="#3e4152"
                                                       BorderThickness="0"
                                                       Cursor="Hand"
                                                       ToolTip="Перезапустить ядро"
                                                       HorizontalAlignment="Right">
                                                <ui:SymbolIcon Symbol="ArrowClockwise24"
                                                               Foreground="White"
                                                               FontSize="14" />
                                            </ui:Button>
                                        </StackPanel>

                                        <ui:Button Grid.Row="2"
                                                   Command="{Binding GenerateRealityConfigCommand}"
                                                   Content="🚀 Создать VLESS-Reality"
                                                   Background="#bd93f9"
                                                   Foreground="#13151b"
                                                   FontWeight="Bold"
                                                   BorderThickness="0"
                                                   HorizontalAlignment="Stretch"
                                                   Cursor="Hand"
                                                   Margin="0,0,0,20" />

                                        <Border Grid.Row="3"
                                                Background="#0a0b0f"
                                                CornerRadius="6"
                                                Padding="10">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <TextBlock Text="{Binding XrayLogs}"
                                                           Foreground="#a0aabf"
                                                           FontFamily="Consolas"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="#1c1e27"
                                        CornerRadius="8"
                                        Padding="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0"
                                              Margin="0,0,0,20">
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="People24"
                                                               Foreground="#8be9fd"
                                                               FontSize="20"
                                                               Margin="0,0,10,0" />
                                                <TextBlock Text="Пользователи (Клиенты)"
                                                           Foreground="White"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                            <ui:Button HorizontalAlignment="Right"
                                                       Command="{Binding AddClientCommand}"
                                                       Content="+ Создать"
                                                       Background="#ffcc00"
                                                       Foreground="#13151b"
                                                       BorderThickness="0"
                                                       Padding="15,6"
                                                       FontWeight="Bold"
                                                       Cursor="Hand" />
                                        </Grid>

                                        <DataGrid Grid.Row="1"
                                                  ItemsSource="{Binding Clients}"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  Background="Transparent"
                                                  RowBackground="Transparent"
                                                  BorderThickness="0"
                                                  GridLinesVisibility="None"
                                                  IsReadOnly="True"
                                                  Foreground="White"
                                                  CanUserResizeColumns="True">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background"
                                                            Value="#282a36" />
                                                    <Setter Property="Foreground"
                                                            Value="#7b8296" />
                                                    <Setter Property="Padding"
                                                            Value="10,12" />
                                                    <Setter Property="BorderBrush"
                                                            Value="#3e4152" />
                                                    <Setter Property="BorderThickness"
                                                            Value="0,0,1,0" />
                                                </Style>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="Padding"
                                                            Value="10,12" />
                                                    <Setter Property="BorderThickness"
                                                            Value="0,0,0,1" />
                                                    <Setter Property="BorderBrush"
                                                            Value="#282a36" />
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding Note}"
                                                                    Width="150">
                                                    <DataGridTextColumn.Header>
                                                        <ui:SymbolIcon Symbol="Note24"
                                                                       ToolTip="Заметка / Контакт"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Binding="{Binding Email}"
                                                                    Width="*">
                                                    <DataGridTextColumn.Header>
                                                        <ui:SymbolIcon Symbol="Mail24"
                                                                       ToolTip="Email"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Binding="{Binding LastIp}"
                                                                    Width="110">
                                                    <DataGridTextColumn.Header>
                                                        <ui:SymbolIcon Symbol="Location24"
                                                                       ToolTip="Последний IP"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Binding="{Binding Country}"
                                                                    Width="80">
                                                    <DataGridTextColumn.Header>
                                                        <ui:SymbolIcon Symbol="Globe24"
                                                                       ToolTip="Страна"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Binding="{Binding ActiveConnections}"
                                                                    Width="60">
                                                    <DataGridTextColumn.Header>
                                                        <ui:SymbolIcon Symbol="Laptop24"
                                                                       ToolTip="Активные устройства"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Binding="{Binding TrafficUsageString}"
                                                                    Width="160">
                                                    <DataGridTextColumn.Header>
                                                        <ui:SymbolIcon Symbol="DataBarHorizontal24"
                                                                       ToolTip="Трафик (Использовано / Лимит)"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Binding="{Binding LastOnlineString}"
                                                                    Width="110">
                                                    <DataGridTextColumn.Header>
                                                        <ui:SymbolIcon Symbol="History24"
                                                                       ToolTip="Последний онлайн"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>

                                                <DataGridTemplateColumn Width="60">
                                                    <DataGridTemplateColumn.Header>
                                                        <ui:SymbolIcon Symbol="ShieldCheckmark24"
                                                                       ToolTip="Контроль (Антифрод)"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTemplateColumn.Header>
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsAntiFraudEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      ToolTip="Включить/Выключить автоматический бан" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn Width="Auto">
                                                    <DataGridTemplateColumn.Header>
                                                        <ui:SymbolIcon Symbol="Settings24"
                                                                       ToolTip="Действия"
                                                                       Foreground="#a0aabf" />
                                                    </DataGridTemplateColumn.Header>
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal"
                                                                        HorizontalAlignment="Right">
                                                                <ui:Button Command="{Binding DataContext.EditClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                           CommandParameter="{Binding}"
                                                                           Background="Transparent"
                                                                           BorderThickness="0"
                                                                           Padding="6"
                                                                           Cursor="Hand"
                                                                           ToolTip="Редактировать">
                                                                    <ui:SymbolIcon Symbol="Edit24"
                                                                                   Foreground="#a0aabf"
                                                                                   FontSize="16" />
                                                                </ui:Button>
                                                                <ui:Button Command="{Binding DataContext.CopyClientLinkCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                           CommandParameter="{Binding}"
                                                                           Background="Transparent"
                                                                           BorderThickness="0"
                                                                           Padding="6"
                                                                           Cursor="Hand"
                                                                           ToolTip="Копировать ссылку">
                                                                    <ui:SymbolIcon Symbol="Link24"
                                                                                   Foreground="#8be9fd"
                                                                                   FontSize="16" />
                                                                </ui:Button>
                                                                <ui:Button Command="{Binding DataContext.ToggleClientAccessCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                           CommandParameter="{Binding}"
                                                                           Background="Transparent"
                                                                           BorderThickness="0"
                                                                           Padding="6"
                                                                           Cursor="Hand"
                                                                           ToolTip="Бан/Разбан">
                                                                    <ui:SymbolIcon FontSize="16">
                                                                        <ui:SymbolIcon.Style>
                                                                            <Style TargetType="ui:SymbolIcon">
                                                                                <Setter Property="Symbol"
                                                                                        Value="Pause24" />
                                                                                <Setter Property="Foreground"
                                                                                        Value="#ffb86c" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsActive}"
                                                                                                 Value="False">
                                                                                        <Setter Property="Symbol"
                                                                                                Value="Play24" />
                                                                                        <Setter Property="Foreground"
                                                                                                Value="#50fa7b" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ui:SymbolIcon.Style>
                                                                    </ui:SymbolIcon>
                                                                </ui:Button>
                                                                <ui:Button Command="{Binding DataContext.ResetClientTrafficCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                           CommandParameter="{Binding}"
                                                                           Background="Transparent"
                                                                           BorderThickness="0"
                                                                           Padding="6"
                                                                           Cursor="Hand"
                                                                           ToolTip="Сброс трафика">
                                                                    <ui:SymbolIcon Symbol="ArrowClockwise24"
                                                                                   Foreground="#ffcc00"
                                                                                   FontSize="16" />
                                                                </ui:Button>
                                                                <ui:Button Command="{Binding DataContext.DeleteClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                           CommandParameter="{Binding}"
                                                                           Background="Transparent"
                                                                           BorderThickness="0"
                                                                           Padding="6"
                                                                           Cursor="Hand"
                                                                           ToolTip="Удалить">
                                                                    <ui:SymbolIcon Symbol="Delete24"
                                                                                   Foreground="#ff5555"
                                                                                   FontSize="16" />
                                                                </ui:Button>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>