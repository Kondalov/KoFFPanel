<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.DeployWizardWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Мастер установки"
                 Width="600"
                 Height="620"
                 MinWidth="550"
                 MinHeight="600"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <Style x:Key="KernelCardRadioStyle"
               TargetType="RadioButton">
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="VerticalAlignment"
                    Value="Stretch" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="CardBorder"
                                Background="#08FFFFFF"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="2"
                                CornerRadius="16"
                                Padding="16"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0" />
                            </Border.RenderTransform>
                            <Grid>
                                <Border x:Name="CheckBadge"
                                        Width="20"
                                        Height="20"
                                        Background="#00f2ff"
                                        CornerRadius="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="-6,-6,0,0"
                                        Visibility="Collapsed">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00f2ff"
                                                          BlurRadius="10"
                                                          ShadowDepth="0"
                                                          Opacity="0.8" />
                                    </Border.Effect>
                                    <TextBlock Text="✓"
                                               Foreground="#000000"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="CardBorder"
                                        Property="Background"
                                        Value="#1AFFFFFF" />
                                <Setter TargetName="CardBorder"
                                        Property="BorderBrush"
                                        Value="#4DFFFFFF" />
                                <Setter TargetName="CardBorder"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-2" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="CardBorder"
                                        Property="BorderBrush"
                                        Value="#00f2ff" />
                                <Setter TargetName="CardBorder"
                                        Property="Background"
                                        Value="#0A00f2ff" />
                                <Setter TargetName="CheckBadge"
                                        Property="Visibility"
                                        Value="Visible" />
                                <Setter TargetName="CardBorder"
                                        Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00f2ff"
                                                          BlurRadius="15"
                                                          ShadowDepth="0"
                                                          Opacity="0.4" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonCancelBtnStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Background"
                    Value="#1AFFFFFF" />
            <Setter Property="BorderBrush"
                    Value="#33FFFFFF" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#B3FFFFFF" />
            <Setter Property="Padding"
                    Value="0,14" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#26FFFFFF" />
                    <Setter Property="Foreground"
                            Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NeonInstallBtnStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0,14" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#00ff88"
                                      Offset="0" />
                        <GradientStop Color="#00cc6a"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00ff88"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.4" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00ff88"
                                              BlurRadius="20"
                                              ShadowDepth="0"
                                              Opacity="0.8" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.8,0.2"
                                 Center="0.8,0.2"
                                 RadiusX="0.5"
                                 RadiusY="0.5">
                <GradientStop Color="#1A00f2ff"
                              Offset="0.0" />
                <GradientStop Color="#000a0a0a"
                              Offset="1.0" />
            </RadialGradientBrush>
        </Grid.Background>

        <Grid Margin="16,36,16,16">
            <Border Background="#E614141E"
                    CornerRadius="20"
                    BorderThickness="1"
                    BorderBrush="#1AFFFFFF">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="30"
                                      ShadowDepth="10"
                                      Opacity="0.5" />
                </Border.Effect>
            </Border>

            <Border Background="#E614141E"
                    CornerRadius="20"
                    BorderThickness="1"
                    BorderBrush="#1AFFFFFF"
                    ClipToBounds="True">
                <Grid>
                    <Border Height="3"
                            VerticalAlignment="Top"
                            CornerRadius="20,20,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#00f2ff"
                                              Offset="0" />
                                <GradientStop Color="#7000ff"
                                              Offset="0.5" />
                                <GradientStop Color="#ff00aa"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,4">
                                <ui:SymbolIcon Symbol="Rocket24"
                                               Foreground="#00f2ff"
                                               FontSize="24"
                                               Margin="0,0,10,0">
                                    <ui:SymbolIcon.Effect>
                                        <DropShadowEffect Color="#00f2ff"
                                                          BlurRadius="10"
                                                          ShadowDepth="0" />
                                    </ui:SymbolIcon.Effect>
                                </ui:SymbolIcon>
                                <TextBlock Text="МАСТЕР УСТАНОВКИ"
                                           FontSize="20"
                                           FontWeight="ExtraBold">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0"
                                                             EndPoint="1,1">
                                            <GradientStop Color="#FFFFFF"
                                                          Offset="0" />
                                            <GradientStop Color="#00f2ff"
                                                          Offset="1" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="Выберите ядро для развертывания на сервере"
                                       Foreground="#B3FFFFFF"
                                       FontSize="12"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Background="#1Affaa00"
                                BorderBrush="#4Dffaa00"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="10"
                                        Background="#26ffaa00"
                                        BorderBrush="#4Dffaa00"
                                        BorderThickness="1"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="⚠️"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="БЕЗОПАСНОСТЬ СЕРВЕРА!"
                                               Foreground="#ffaa00"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               Margin="0,0,0,2" />
                                    <TextBlock Text="Настройте SSH-ключи. Использование обычного пароля делает сервер уязвимым!"
                                               Foreground="#E6ffaa00"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2"
                              Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="ВЫБЕРИТЕ ЯДРО"
                                       Foreground="#999999"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="1"
                                    Height="1"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop Color="#33FFFFFF"
                                                      Offset="0" />
                                        <GradientStop Color="#00FFFFFF"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3"
                              Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <RadioButton Grid.Row="0"
                                         Grid.Column="0"
                                         GroupName="CoreSelection"
                                         Style="{StaticResource KernelCardRadioStyle}"
                                         IsChecked="{Binding IsXraySelected}"
                                         IsEnabled="{Binding IsNotInstalling}">
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="ShieldCheckmark24"
                                                   Foreground="#00f2ff"
                                                   FontSize="32"
                                                   Margin="0,0,0,10"
                                                   HorizontalAlignment="Center" />
                                    <TextBlock Text="XRAY-CORE"
                                               Foreground="White"
                                               FontWeight="ExtraBold"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="Проверенное и стабильное ядро"
                                               Foreground="#a0aabf"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10" />

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <Border Background="#1AFFFFFF"
                                                CornerRadius="6"
                                                Padding="6,2"
                                                Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Сервер: "
                                                           Foreground="#7b8296"
                                                           FontSize="10" />
                                                <TextBlock Text="{Binding DataContext.XrayCurrentVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Foreground="#ff5555"
                                                           FontSize="10"
                                                           FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#1AFFFFFF"
                                                CornerRadius="6"
                                                Padding="6,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="GitHub: "
                                                           Foreground="#7b8296"
                                                           FontSize="10" />
                                                <TextBlock Text="{Binding DataContext.XrayLatestVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Foreground="#00ff88"
                                                           FontSize="10"
                                                           FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Grid.Row="0"
                                         Grid.Column="2"
                                         GroupName="CoreSelection"
                                         Style="{StaticResource KernelCardRadioStyle}"
                                         IsChecked="{Binding IsSingBoxSelected}"
                                         IsEnabled="{Binding IsNotInstalling}">
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Flash24"
                                                   Foreground="#ffaa00"
                                                   FontSize="32"
                                                   Margin="0,0,0,10"
                                                   HorizontalAlignment="Center" />
                                    <TextBlock Text="SING-BOX"
                                               Foreground="White"
                                               FontWeight="ExtraBold"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="Современное легкое ядро"
                                               Foreground="#a0aabf"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10" />

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <Border Background="#1AFFFFFF"
                                                CornerRadius="6"
                                                Padding="6,2"
                                                Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Сервер: "
                                                           Foreground="#7b8296"
                                                           FontSize="10" />
                                                <TextBlock Text="{Binding DataContext.SingBoxCurrentVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Foreground="#ff5555"
                                                           FontSize="10"
                                                           FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#1AFFFFFF"
                                                CornerRadius="6"
                                                Padding="6,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="GitHub: "
                                                           Foreground="#7b8296"
                                                           FontSize="10" />
                                                <TextBlock Text="{Binding DataContext.SingBoxLatestVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Foreground="#00ff88"
                                                           FontSize="10"
                                                           FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Grid.Row="2"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="3"
                                         GroupName="CoreSelection"
                                         Style="{StaticResource KernelCardRadioStyle}"
                                         IsChecked="{Binding IsCustomSelected}"
                                         IsEnabled="{Binding IsNotInstalling}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="DocumentEdit24"
                                                   Foreground="#ff00aa"
                                                   FontSize="28"
                                                   Margin="0,0,12,0"
                                                   VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="СВОЯ КОНФИГУРАЦИЯ"
                                                   Foreground="White"
                                                   FontWeight="ExtraBold"
                                                   FontSize="14"
                                                   Margin="0,0,0,2" />
                                        <TextBlock Text="Загрузить собственный config.json"
                                                   Foreground="#a0aabf"
                                                   FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>
                        </Grid>

                        <TextBlock Grid.Row="4"
                                   Text="{Binding StatusMessage}"
                                   Foreground="#00ff88"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />

                        <Grid Grid.Row="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ui:Button Grid.Column="0"
                                       Command="{Binding CancelCommand}"
                                       IsEnabled="{Binding IsNotInstalling}"
                                       Style="{StaticResource NeonCancelBtnStyle}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="✕"
                                               Margin="0,0,6,0"
                                               FontSize="12" />
                                    <TextBlock Text="ОТМЕНА"
                                               FontWeight="Bold"
                                               FontSize="12" />
                                </StackPanel>
                            </ui:Button>

                            <ui:Button Grid.Column="2"
                                       Command="{Binding StartInstallCommand}"
                                       IsEnabled="{Binding IsNotInstalling}"
                                       Style="{StaticResource NeonInstallBtnStyle}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="▶"
                                               Margin="0,0,6,0"
                                               FontSize="12"
                                               Foreground="#000000" />
                                    <TextBlock Text="НАЧАТЬ УСТАНОВКУ"
                                               FontWeight="ExtraBold"
                                               Foreground="#000000"
                                               FontSize="12" />
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>