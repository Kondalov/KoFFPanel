<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.DeployWizardWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Мастер установки"
                 Height="650"
                 Width="480"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0b0f"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Rocket24"
                               Foreground="#ffcc00"
                               FontSize="24"
                               Margin="0,0,10,0" />
                <TextBlock Text="Мастер авто-установки"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White" />
            </StackPanel>
            <TextBlock Text="Выберите ядро для развертывания на сервере"
                       Foreground="#7b8296"
                       FontSize="14"
                       Margin="0,5,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1">

            <RadioButton IsChecked="{Binding IsXraySelected}"
                         GroupName="CoreSelection"
                         Margin="0,0,0,10"
                         IsEnabled="{Binding IsNotInstalling}">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="15"
                                Cursor="Hand">
                            <StackPanel>
                                <TextBlock Text="Xray-core (Рекомендуется)"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="0,0,0,5" />
                                <TextBlock Text="Установка последней версии Xray с поддержкой VLESS, Reality, TCP/gRPC."
                                           Foreground="#a0aabf"
                                           TextWrapping="Wrap" />

                                <StackPanel Orientation="Horizontal"
                                            Margin="0,10,0,0">
                                    <Border Background="#13151b"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="На сервере: "
                                                       Foreground="#7b8296"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding DataContext.XrayCurrentVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       Foreground="#ff5555"
                                                       FontSize="11"
                                                       FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#13151b"
                                            CornerRadius="4"
                                            Padding="6,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="На GitHub: "
                                                       Foreground="#7b8296"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding DataContext.XrayLatestVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       Foreground="#50fa7b"
                                                       FontSize="11"
                                                       FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#1c1e27" />
                                <Setter Property="BorderBrush"
                                        Value="#ffcc00" />
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="False">
                                <Setter Property="Background"
                                        Value="#13151b" />
                                <Setter Property="BorderBrush"
                                        Value="#282a36" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
            </RadioButton>

            <RadioButton IsChecked="{Binding IsSingBoxSelected}"
                         GroupName="CoreSelection"
                         Margin="0,0,0,10"
                         IsEnabled="{Binding IsNotInstalling}">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="15"
                                Cursor="Hand">
                            <StackPanel>
                                <TextBlock Text="Sing-box"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="0,0,0,5" />
                                <TextBlock Text="Легковесное универсальное ядро с отличной производительностью."
                                           Foreground="#a0aabf"
                                           TextWrapping="Wrap" />

                                <StackPanel Orientation="Horizontal"
                                            Margin="0,10,0,0">
                                    <Border Background="#13151b"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="На сервере: "
                                                       Foreground="#7b8296"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding DataContext.SingBoxCurrentVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       Foreground="#ff5555"
                                                       FontSize="11"
                                                       FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#13151b"
                                            CornerRadius="4"
                                            Padding="6,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="На GitHub: "
                                                       Foreground="#7b8296"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding DataContext.SingBoxLatestVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       Foreground="#50fa7b"
                                                       FontSize="11"
                                                       FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#1c1e27" />
                                <Setter Property="BorderBrush"
                                        Value="#ffcc00" />
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="False">
                                <Setter Property="Background"
                                        Value="#13151b" />
                                <Setter Property="BorderBrush"
                                        Value="#282a36" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
            </RadioButton>

            <RadioButton IsChecked="{Binding IsCustomSelected}"
                         GroupName="CoreSelection"
                         Margin="0,0,0,15"
                         IsEnabled="{Binding IsNotInstalling}">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="15"
                                Cursor="Hand">
                            <StackPanel>
                                <TextBlock Text="Своя конфигурация"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="0,0,0,5" />
                                <TextBlock Text="Загрузить свой собственный config.json без стандартных шаблонов."
                                           Foreground="#a0aabf"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#1c1e27" />
                                <Setter Property="BorderBrush"
                                        Value="#ffcc00" />
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="False">
                                <Setter Property="Background"
                                        Value="#13151b" />
                                <Setter Property="BorderBrush"
                                        Value="#282a36" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
            </RadioButton>

            <Border Background="#1c1e27"
                    CornerRadius="8"
                    Padding="15"
                    BorderBrush="#3e4152"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,4">
                            <ui:SymbolIcon Symbol="ArrowSync24"
                                           Foreground="#8be9fd"
                                           FontSize="16"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="Умное автообновление"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Ежедневно проверять GitHub и ставить новую версию (в 03:00)"
                                   Foreground="#7b8296"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1"
                                     IsChecked="{Binding IsAutoUpdateEnabled}"
                                     IsEnabled="{Binding IsNotInstalling}"
                                     VerticalAlignment="Center" />
                </Grid>
            </Border>

        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#50fa7b"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,15"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   TextAlignment="Center" />

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0"
                       Command="{Binding CancelCommand}"
                       IsEnabled="{Binding IsNotInstalling}"
                       Content="Отмена"
                       HorizontalAlignment="Stretch"
                       Background="#1c1e27"
                       Foreground="White"
                       BorderThickness="0" />
            <ui:Button Grid.Column="2"
                       Command="{Binding StartInstallCommand}"
                       IsEnabled="{Binding IsNotInstalling}"
                       Content="Запустить установку"
                       HorizontalAlignment="Stretch"
                       Background="#ffcc00"
                       Foreground="#13151b"
                       FontWeight="Bold"
                       BorderThickness="0" />
        </Grid>
    </Grid>
</ui:FluentWindow>