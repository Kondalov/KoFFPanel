<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.ClientProtocolsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding WindowTitle}"
                 Height="680"
                 Width="600"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize">

    <Border BorderThickness="0,3,0,0">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">
                <GradientStop Color="#bd93f9"
                              Offset="0" />
                <GradientStop Color="#00f2ff"
                              Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid Margin="32,20,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,24"
                        VerticalAlignment="Center">
                <Border Width="48"
                        Height="48"
                        CornerRadius="14"
                        Margin="0,0,16,0"
                        BorderThickness="1"
                        BorderBrush="#4Dbd93f9">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop Color="#26bd93f9"
                                          Offset="0" />
                            <GradientStop Color="#2600f2ff"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <ui:SymbolIcon Symbol="Apps24"
                                   Foreground="#bd93f9"
                                   FontSize="24" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Доступ к протоколам"
                               Foreground="#B3FFFFFF"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Email}"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="ExtraBlack" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1">

                <Border Background="#0DFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="⚡"
                                           FontSize="16"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="VLESS (Reality)"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding IsVlessEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Text="{Binding VlessLink}"
                                        IsReadOnly="True"
                                        Foreground="#B3FFFFFF"
                                        FontWeight="Bold"
                                        Background="#0AFFFFFF"
                                        BorderThickness="1"
                                        BorderBrush="#1AFFFFFF"
                                        Height="36" />
                            <ui:Button Grid.Column="2"
                                       Command="{Binding CopyVlessCommand}"
                                       Height="36"
                                       Background="#1A00f2ff"
                                       BorderThickness="1"
                                       BorderBrush="#3300f2ff"
                                       Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Copy24"
                                                   Foreground="#00f2ff"
                                                   Margin="0,0,6,0" />
                                    <TextBlock Foreground="#00f2ff"
                                               FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"
                                                        Value="Копировать" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVlessCopied}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="Скопировано" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#0DFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="🚀"
                                           FontSize="16"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Hysteria 2"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <Border Background="#1Aff00aa"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="UDP"
                                               Foreground="#ff00aa"
                                               FontSize="10"
                                               FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding IsHysteria2Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Text="{Binding Hysteria2Link}"
                                        IsReadOnly="True"
                                        Foreground="#B3FFFFFF"
                                        FontWeight="Bold"
                                        Background="#0AFFFFFF"
                                        BorderThickness="1"
                                        BorderBrush="#1AFFFFFF"
                                        Height="36" />
                            <ui:Button Grid.Column="2"
                                       Command="{Binding CopyHysteria2Command}"
                                       Height="36"
                                       Background="#1Abd93f9"
                                       BorderThickness="1"
                                       BorderBrush="#33bd93f9"
                                       Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Copy24"
                                                   Foreground="#bd93f9"
                                                   Margin="0,0,6,0" />
                                    <TextBlock Foreground="#bd93f9"
                                               FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"
                                                        Value="Копировать" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHysteria2Copied}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="Скопировано" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#0DFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="🛡️"
                                           FontSize="16"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="TrustTunnel (MASQUE HTTP/3)"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <Border Background="#1Aff00aa"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="UDP"
                                               Foreground="#ff00aa"
                                               FontSize="10"
                                               FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding IsTrustTunnelEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Text="{Binding TrustTunnelLink}"
                                        IsReadOnly="True"
                                        Foreground="#B3FFFFFF"
                                        FontWeight="Bold"
                                        Background="#0AFFFFFF"
                                        BorderThickness="1"
                                        BorderBrush="#1AFFFFFF"
                                        Height="36" />
                            <ui:Button Grid.Column="2"
                                       Command="{Binding CopyTrustTunnelCommand}"
                                       Height="36"
                                       Background="#1A50fa7b"
                                       BorderThickness="1"
                                       BorderBrush="#3350fa7b"
                                       Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Copy24"
                                                   Foreground="#50fa7b"
                                                   Margin="0,0,6,0" />
                                    <TextBlock Foreground="#50fa7b"
                                               FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"
                                                        Value="Копировать" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTrustTunnelCopied}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="Скопировано" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
                <ui:Button Command="{Binding CancelCommand}"
                           Content="Отмена"
                           Background="#1AFFFFFF"
                           Foreground="#B3FFFFFF"
                           BorderThickness="1"
                           BorderBrush="#33FFFFFF"
                           Padding="24,12"
                           Cursor="Hand"
                           Margin="0,0,12,0" />
                <ui:Button Command="{Binding SaveCommand}"
                           Content="Сохранить настройки"
                           Foreground="Black"
                           FontWeight="Bold"
                           BorderThickness="0"
                           Padding="24,12"
                           Cursor="Hand">
                    <ui:Button.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop Color="#bd93f9"
                                          Offset="0" />
                            <GradientStop Color="#00f2ff"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </ui:Button.Background>
                </ui:Button>
            </StackPanel>
        </Grid>
    </Border>
</ui:FluentWindow>