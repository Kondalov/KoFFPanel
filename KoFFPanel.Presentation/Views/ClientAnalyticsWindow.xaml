<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.ClientAnalyticsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding Title}"
                 Height="550"
                 Width="750"
                 WindowStartupLocation="CenterOwner"
                 Background="#0a0b0f"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/KoFFPanel.Presentation;component/Styles/CabinetWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding Title}"
                     Background="Transparent"
                     Foreground="White"
                     Padding="15,5" />

        <TabControl Grid.Row="1"
                    Margin="20"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White">

            <TabItem Header="Журнал IP адресов">
                <Border Background="#1c1e27"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,15,0,0">
                    <DataGrid ItemsSource="{Binding ConnectionLogs}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              IsReadOnly="True"
                              Foreground="White"
                              ColumnHeaderStyle="{StaticResource StandardDataGridHeader}"
                              CellStyle="{StaticResource StandardDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding IpAddress}"
                                                Header="IP Адрес"
                                                Width="*" />
                            <DataGridTextColumn Binding="{Binding Country}"
                                                Header="Страна"
                                                Width="80" />
                            <DataGridTextColumn Binding="{Binding FirstSeen, StringFormat='dd MMM HH:mm'}"
                                                Header="Первое подключение"
                                                Width="150" />
                            <DataGridTextColumn Binding="{Binding LastSeen, StringFormat='dd MMM HH:mm'}"
                                                Header="Последняя активность"
                                                Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Расход трафика (По дням)">
                <Border Background="#1c1e27"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,15,0,0">
                    <DataGrid ItemsSource="{Binding TrafficLogs}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              IsReadOnly="True"
                              Foreground="White"
                              ColumnHeaderStyle="{StaticResource StandardDataGridHeader}"
                              CellStyle="{StaticResource StandardDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Date, StringFormat='dd MMMM yyyy'}"
                                                Header="Дата"
                                                Width="*" />
                            <DataGridTextColumn Binding="{Binding TrafficUsed}"
                                                Header="Скачано трафика"
                                                Width="200" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Нарушения (DMCA)">
                <Border Background="#1c1e27"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,15,0,0">
                    <DataGrid ItemsSource="{Binding ViolationLogs}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              IsReadOnly="True"
                              Foreground="#ff5555"
                              ColumnHeaderStyle="{StaticResource StandardDataGridHeader}"
                              CellStyle="{StaticResource StandardDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Date, StringFormat='dd MMM yyyy, HH:mm'}"
                                                Header="Дата и время"
                                                Width="180" />
                            <DataGridTextColumn Binding="{Binding ViolationType}"
                                                Header="Тип нарушения (Заблокировано)"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

        </TabControl>
    </Grid>
</ui:FluentWindow>