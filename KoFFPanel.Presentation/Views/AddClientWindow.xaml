<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.AddClientWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Новый пользователь"
                 Height="400"
                 Width="450"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#13151b"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,25"
                    VerticalAlignment="Center">
            <Border Background="#bd93f9"
                    CornerRadius="8"
                    Padding="8"
                    Margin="0,0,15,0">
                <ui:SymbolIcon Symbol="PersonAdd24"
                               Foreground="#13151b"
                               FontSize="20" />
            </Border>
            <TextBlock Text="{Binding WindowTitle}"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Имя пользователя (Только латиница/цифры)"
                       Foreground="#a0aabf"
                       FontSize="14"
                       Margin="0,0,0,8"
                       FontWeight="SemiBold" />
            <ui:TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Например: Kostya_Phone"
                        Foreground="White"
                        Background="#1c1e27"
                        BorderBrush="#3e4152"
                        FontSize="16"
                        Padding="12"
                        Height="40" />

            <Grid Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Лимит (ГБ, 0 = Безлимит)"
                               Foreground="#a0aabf"
                               FontSize="14"
                               Margin="0,0,0,8"
                               FontWeight="SemiBold" />
                    <ui:TextBox Text="{Binding TrafficLimitGb, UpdateSourceTrigger=PropertyChanged}"
                                Foreground="White"
                                Background="#1c1e27"
                                BorderBrush="#3e4152"
                                FontSize="16"
                                Padding="12"
                                Height="40" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Истекает (Дата)"
                               Foreground="#a0aabf"
                               FontSize="14"
                               Margin="0,0,0,8"
                               FontWeight="SemiBold" />
                    <DatePicker SelectedDate="{Binding ExpiryDate}"
                                FontSize="14"
                                Height="40"
                                Background="#1c1e27"
                                Foreground="Black" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Заметка (Контакт, Telegram, устройство)"
                       Foreground="#a0aabf"
                       FontSize="14"
                       Margin="0,15,0,8"
                       FontWeight="SemiBold" />
            <ui:TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Например: Оплатил до марта, тг @ivan"
                        Foreground="White"
                        Background="#1c1e27"
                        BorderBrush="#3e4152"
                        FontSize="16"
                        Padding="12"
                        Height="40" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <ui:Button Command="{Binding CancelCommand}"
                       Content="Отмена"
                       Background="Transparent"
                       Foreground="#a0aabf"
                       BorderThickness="0"
                       Padding="20,10"
                       Cursor="Hand"
                       Margin="0,0,10,0" />
            <ui:Button Command="{Binding SaveCommand}"
                       Content="{Binding ActionButtonText}"
                       Background="#ffcc00"
                       Foreground="#13151b"
                       FontWeight="Bold"
                       BorderThickness="0"
                       Padding="25,10"
                       Cursor="Hand" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>