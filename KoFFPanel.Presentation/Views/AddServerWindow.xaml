<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.AddServerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding WindowTitle}"
                 Height="600"
                 Width="440"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0b0f"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding WindowTitle}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,20" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="Название в списке"
                       Foreground="#7b8296"
                       Margin="0,0,0,5" />
            <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,15"
                        Background="#1c1e27"
                        Foreground="White"
                        BorderBrush="#3e4152" />

            <TextBlock Text="IP-адрес сервера"
                       Foreground="#7b8296"
                       Margin="0,0,0,5" />
            <ui:TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,15"
                        Background="#1c1e27"
                        Foreground="White"
                        BorderBrush="#3e4152" />

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Пользователь (root)"
                               Foreground="#7b8296"
                               Margin="0,0,0,5" />
                    <ui:TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                Background="#1c1e27"
                                Foreground="White"
                                BorderBrush="#3e4152" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Порт (22)"
                               Foreground="#7b8296"
                               Margin="0,0,0,5" />
                    <ui:TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                Background="#1c1e27"
                                Foreground="White"
                                BorderBrush="#3e4152" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Пароль (или Passphrase для ключа)"
                       Foreground="#7b8296"
                       Margin="0,0,0,5" />
            <ui:TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,15"
                        Background="#1c1e27"
                        Foreground="White"
                        BorderBrush="#3e4152" />

            <TextBlock Text="Путь к приватному ключу из файла"
                       Foreground="#7b8296"
                       Margin="0,0,0,5" />
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox Grid.Column="0"
                            Text="{Binding KeyPath, UpdateSourceTrigger=PropertyChanged}"
                            Background="#1c1e27"
                            Foreground="White"
                            BorderBrush="#3e4152" />

                <ui:Button Grid.Column="2"
                           Command="{Binding BrowseKeyCommand}"
                           Content="Обзор..."
                           Padding="15,6"
                           Background="#282a36"
                           Foreground="White"
                           BorderBrush="#3e4152"
                           Cursor="Hand" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="0,10,0,20">
            <ui:Button Command="{Binding CheckConnectionCommand}"
                       IsEnabled="{Binding IsNotChecking}"
                       Content="Проверить SSH-подключение"
                       HorizontalAlignment="Stretch"
                       Background="#282a36"
                       Foreground="White"
                       BorderBrush="#3e4152"
                       Margin="0,0,0,10" />

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#ffcc00"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold" />
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0"
                       Command="{Binding CancelCommand}"
                       Content="Отмена"
                       HorizontalAlignment="Stretch"
                       Background="#1c1e27"
                       Foreground="White"
                       BorderThickness="0" />
            <ui:Button Grid.Column="2"
                       Command="{Binding SaveCommand}"
                       Content="Сохранить"
                       HorizontalAlignment="Stretch"
                       Background="#ffcc00"
                       Foreground="#13151b"
                       FontWeight="Bold"
                       BorderThickness="0" />
        </Grid>
    </Grid>
</ui:FluentWindow>