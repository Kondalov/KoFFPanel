<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.EditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding WindowTitle}"
                 Height="700"
                 Width="1000"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#13151b"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding WindowTitle}"
                     Background="Transparent"
                     Foreground="White"
                     Padding="10,5" />

        <Border Grid.Row="1"
                Background="#1c1e27"
                BorderBrush="#2a2d3d"
                BorderThickness="0,1,0,1"
                Padding="10">
            <StackPanel Orientation="Horizontal">
                <ui:Button Command="{Binding SaveCommand}"
                           Background="#0078D4"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="15,8"
                           Margin="0,0,10,0"
                           Cursor="Hand"
                           ToolTip="Сохранить изменения (Ctrl+S)">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24"
                                       Foreground="White"
                                       Margin="0,0,8,0" />
                        <TextBlock Text="Сохранить"
                                   FontWeight="Bold" />
                    </StackPanel>
                    <ui:Button.Effect>
                        <DropShadowEffect Color="#0078D4"
                                          BlurRadius="10"
                                          ShadowDepth="0"
                                          Opacity="0.5" />
                    </ui:Button.Effect>
                </ui:Button>

                <ui:Button Command="{Binding UndoCommand}"
                           Background="#282a36"
                           Foreground="#a0aabf"
                           BorderThickness="0"
                           Padding="10,8"
                           Margin="0,0,5,0"
                           Cursor="Hand"
                           ToolTip="Отменить (Ctrl+Z)">
                    <ui:SymbolIcon Symbol="ArrowUndo24" />
                </ui:Button>
                <ui:Button Command="{Binding RedoCommand}"
                           Background="#282a36"
                           Foreground="#a0aabf"
                           BorderThickness="0"
                           Padding="10,8"
                           Margin="0,0,15,0"
                           Cursor="Hand"
                           ToolTip="Вернуть (Ctrl+Y)">
                    <ui:SymbolIcon Symbol="ArrowRedo24" />
                </ui:Button>

                <TextBlock Text="{Binding SaveStatus}"
                           Foreground="{Binding StatusColor}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="10,0,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#13151b">
            <wv2:WebView2 x:Name="EditorWebView"
                          DefaultBackgroundColor="Transparent" />
        </Border>
    </Grid>
</ui:FluentWindow>