<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.CustomConfigWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Своя конфигурация"
                 Width="560"
                 Height="700"
                 MinWidth="500"
                 MinHeight="650"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <Style x:Key="NeonCancelBtn"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Background"
                    Value="#1AFFFFFF" />
            <Setter Property="BorderBrush"
                    Value="#33FFFFFF" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#B3FFFFFF" />
            <Setter Property="Padding"
                    Value="0,14" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#26FFFFFF" />
                    <Setter Property="Foreground"
                            Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NeonApplyBtn"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0,14" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#3b82f6"
                                      Offset="0" />
                        <GradientStop Color="#1d4ed8"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#3b82f6"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.4" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#3b82f6"
                                              BlurRadius="20"
                                              ShadowDepth="0"
                                              Opacity="0.8" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.5"
                                 Center="0.5,0.5"
                                 RadiusX="0.8"
                                 RadiusY="0.8">
                <GradientStop Color="#1A3b82f6"
                              Offset="0.0" />
                <GradientStop Color="#000a0a0a"
                              Offset="1.0" />
            </RadialGradientBrush>
        </Grid.Background>

        <Grid Margin="16,36,16,16">
            <Border Background="#E614141E"
                    CornerRadius="20"
                    BorderThickness="1"
                    BorderBrush="#1AFFFFFF">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="30"
                                      ShadowDepth="10"
                                      Opacity="0.5" />
                </Border.Effect>
            </Border>

            <Border Background="#E614141E"
                    CornerRadius="20"
                    BorderThickness="1"
                    BorderBrush="#1AFFFFFF"
                    ClipToBounds="True">
                <Grid>
                    <Border Height="3"
                            VerticalAlignment="Top"
                            CornerRadius="20,20,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#7000ff"
                                              Offset="0" />
                                <GradientStop Color="#ff00aa"
                                              Offset="0.5" />
                                <GradientStop Color="#00f2ff"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,4">
                                <ui:SymbolIcon Symbol="Settings24"
                                               Foreground="#3b82f6"
                                               FontSize="24"
                                               Margin="0,0,10,0" />
                                <TextBlock Text="СВОЯ КОНФИГУРАЦИЯ"
                                           FontSize="18"
                                           FontWeight="ExtraBold">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0"
                                                             EndPoint="1,1">
                                            <GradientStop Color="#FFFFFF"
                                                          Offset="0" />
                                            <GradientStop Color="#3b82f6"
                                                          Offset="1" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="Настройте параметры сервера под свои задачи"
                                       Foreground="#B3FFFFFF"
                                       FontSize="12"
                                       Margin="34,0,0,0" />
                        </StackPanel>

                        <Grid Grid.Row="1"
                              Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,6">
                                    <TextBlock Text="📦"
                                               Margin="0,0,6,0"
                                               Opacity="0.7"
                                               FontSize="12" />
                                    <TextBlock Text="ЯДРО"
                                               Foreground="#B3FFFFFF"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                                <ComboBox ItemsSource="{Binding Kernels}"
                                          SelectedItem="{Binding SelectedKernel}"
                                          Background="#0DFFFFFF"
                                          Foreground="White"
                                          BorderBrush="#1AFFFFFF"
                                          Padding="10,6"
                                          FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,6">
                                    <TextBlock Text="🌐"
                                               Margin="0,0,6,0"
                                               Opacity="0.7"
                                               FontSize="12" />
                                    <TextBlock Text="ПРОТОКОЛ IP"
                                               Foreground="#B3FFFFFF"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                                <ComboBox ItemsSource="{Binding IpProtocols}"
                                          SelectedItem="{Binding SelectedIpProtocol}"
                                          Background="#0DFFFFFF"
                                          Foreground="White"
                                          BorderBrush="#1AFFFFFF"
                                          Padding="10,6"
                                          FontSize="13" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2"
                                    Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <TextBlock Text="🎭"
                                           Margin="0,0,6,0"
                                           Opacity="0.7"
                                           FontSize="12" />
                                <TextBlock Text="ВЫБЕРИТЕ SNI (МАСКИРОВКА)"
                                           Foreground="#B3FFFFFF"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <ui:TextBox Text="{Binding SniInput, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Впишите свой SNI..."
                                        Background="#0DFFFFFF"
                                        Foreground="White"
                                        BorderBrush="#1AFFFFFF"
                                        Padding="10,8"
                                        FontSize="13"
                                        Margin="0,0,0,8" />
                            <ComboBox ItemsSource="{Binding TopSniList}"
                                      SelectedItem="{Binding SelectedSni}"
                                      Background="#1AFFFFFF"
                                      Foreground="#B3FFFFFF"
                                      BorderBrush="#33FFFFFF"
                                      Padding="10,6"
                                      ToolTip="Или выберите из ТОП-10" />
                        </StackPanel>

                        <Border Grid.Row="3"
                                Height="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">
                                    <GradientStop Color="#00FFFFFF"
                                                  Offset="0" />
                                    <GradientStop Color="#1AFFFFFF"
                                                  Offset="0.5" />
                                    <GradientStop Color="#00FFFFFF"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <StackPanel Grid.Row="4"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <Border Width="32"
                                    Height="32"
                                    CornerRadius="8"
                                    Background="#1A00f2ff"
                                    BorderBrush="#3300f2ff"
                                    BorderThickness="1"
                                    Margin="0,0,10,0">
                                <TextBlock Text="🔌"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Настройки подключения"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="13" />
                                <TextBlock Text="Порт и идентификаторы"
                                           Foreground="#B3FFFFFF"
                                           FontSize="11" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="5"
                                    Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <TextBlock Text="🔗"
                                           Margin="0,0,6,0"
                                           Opacity="0.7"
                                           FontSize="12" />
                                <TextBlock Text="ПОРТ ПОДКЛЮЧЕНИЯ"
                                           Foreground="#B3FFFFFF"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <ui:TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="1-65535"
                                        Background="#0DFFFFFF"
                                        Foreground="White"
                                        BorderBrush="#1AFFFFFF"
                                        Padding="10,8"
                                        FontSize="13"
                                        FontFamily="Consolas" />
                        </StackPanel>

                        <StackPanel Grid.Row="6"
                                    Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <TextBlock Text="🆔"
                                           Margin="0,0,6,0"
                                           Opacity="0.7"
                                           FontSize="12" />
                                <TextBlock Text="UUID КЛИЕНТА"
                                           Foreground="#B3FFFFFF"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox Grid.Column="0"
                                            Text="{Binding Uuid, UpdateSourceTrigger=PropertyChanged}"
                                            Background="#1Affaa00"
                                            Foreground="#ffaa00"
                                            BorderBrush="#4Dffaa00"
                                            Padding="10,8"
                                            FontSize="13"
                                            FontFamily="Consolas" />
                                <ui:Button Grid.Column="2"
                                           Command="{Binding GenerateUuidCommand}"
                                           Background="#1AFFFFFF"
                                           BorderBrush="#33FFFFFF"
                                           Padding="12,8"
                                           Cursor="Hand"
                                           ToolTip="Сгенерировать новый UUID">
                                    <TextBlock Text="🔄"
                                               FontSize="14" />
                                </ui:Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="7"
                                    Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <TextBlock Text="🔑"
                                           Margin="0,0,6,0"
                                           Opacity="0.7"
                                           FontSize="12" />
                                <TextBlock Text="SHORT ID (REALITY)"
                                           Foreground="#B3FFFFFF"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <ui:TextBox Text="{Binding ShortId, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Например: 1965d789"
                                        Background="#0DFFFFFF"
                                        Foreground="White"
                                        BorderBrush="#1AFFFFFF"
                                        Padding="10,8"
                                        FontSize="13"
                                        FontFamily="Consolas" />
                        </StackPanel>

                        <Border Grid.Row="8"
                                Margin="0,16,0,16"
                                Padding="12,10"
                                CornerRadius="10"
                                BorderThickness="1"
                                VerticalAlignment="Bottom">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                    <Setter Property="Background"
                                            Value="#1A00ff88" />
                                    <Setter Property="BorderBrush"
                                            Value="#4D00ff88" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsError}"
                                                     Value="True">
                                            <Setter Property="Background"
                                                    Value="#1Aff4444" />
                                            <Setter Property="BorderBrush"
                                                    Value="#4Dff4444" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusMessage}"
                                                     Value="">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusMessage}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusMessage}"
                                                     Value="Заполните данные для конфигурации">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"
                                       FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"
                                                Value="#00ff88" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsError}"
                                                         Value="True">
                                                <Setter Property="Foreground"
                                                        Value="#ff4444" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Grid Grid.Row="9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ui:Button Grid.Column="0"
                                       Command="{Binding CancelCommand}"
                                       Style="{StaticResource NeonCancelBtn}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="✕"
                                               Margin="0,0,6,0"
                                               FontSize="11" />
                                    <TextBlock Text="ОТМЕНА"
                                               FontWeight="Bold"
                                               FontSize="12" />
                                </StackPanel>
                            </ui:Button>

                            <ui:Button Grid.Column="2"
                                       Command="{Binding ApplyConfigCommand}"
                                       Style="{StaticResource NeonApplyBtn}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="✓"
                                               Margin="0,0,6,0"
                                               FontSize="12" />
                                    <TextBlock Text="ПРИМЕНИТЬ"
                                               FontWeight="ExtraBold"
                                               FontSize="12" />
                                </StackPanel>
                            </ui:Button>
                        </Grid>

                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>