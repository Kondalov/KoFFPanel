<ui:FluentWindow x:Class="KoFFPanel.Presentation.Views.ClientConfigWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Конфигурация клиента"
                 Width="640"
                 Height="740"
                 WindowStartupLocation="CenterOwner"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <Style x:Key="InvisibleScrollBar"
               TargetType="ScrollBar">
            <Setter Property="Width"
                    Value="0" />
            <Setter Property="Height"
                    Value="0" />
            <Setter Property="Background"
                    Value="Transparent" />
        </Style>

        <Style x:Key="NeonCopyBtnStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Background"
                    Value="#0AFFFFFF" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="8" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="CornerRadius"
                    Value="8" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#1AFFFFFF" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="1" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.3"
                                 Center="0.5,0.3"
                                 RadiusX="0.8"
                                 RadiusY="0.8">
                <GradientStop Color="#1A00ff88"
                              Offset="0.0" />
                <GradientStop Color="#1A7000ff"
                              Offset="0.5" />
                <GradientStop Color="#000a0a0a"
                              Offset="1.0" />
            </RadialGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Конфигурация клиента"
                     Background="Transparent"
                     Foreground="White"
                     Padding="15,5" />

        <Grid Grid.Row="1"
              Margin="24,10,24,24">
            <Border Background="#E614141E"
                    CornerRadius="24"
                    BorderThickness="1"
                    BorderBrush="#3300f2ff">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="40"
                                      ShadowDepth="10"
                                      Opacity="0.6" />
                </Border.Effect>

                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,24"
                                HorizontalAlignment="Center">
                        <Border Width="64"
                                Height="64"
                                CornerRadius="32"
                                Background="#1A00f2ff"
                                BorderBrush="#4D00f2ff"
                                BorderThickness="2"
                                Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="Person24"
                                           Foreground="#00f2ff"
                                           FontSize="32"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                <ui:SymbolIcon.Effect>
                                    <DropShadowEffect Color="#00f2ff"
                                                      BlurRadius="15"
                                                      ShadowDepth="0"
                                                      Opacity="0.8" />
                                </ui:SymbolIcon.Effect>
                            </ui:SymbolIcon>
                        </Border>
                        <TextBlock Text="{Binding Email, StringFormat='КЛЮЧИ ДЛЯ {0}'}"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="ExtraBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Скопируйте нужный формат для подключения"
                                   Foreground="#B3FFFFFF"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Height="1"
                            Background="#1AFFFFFF"
                            Margin="0,0,0,24" />

                    <StackPanel Grid.Row="2">

                        <Border Background="#0DFFFFFF"
                                Padding="16"
                                CornerRadius="16"
                                Margin="0,0,0,16"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="🌐"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="HTTP ПОДПИСКА (Hiddify / v2rayNG)"
                                                   Foreground="#ff00aa"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                    </StackPanel>
                                    <ui:TextBox Text="{Binding HttpLink, Mode=OneWay}"
                                                IsReadOnly="True"
                                                Background="Transparent"
                                                Foreground="#E6FFFFFF"
                                                BorderThickness="0"
                                                Padding="0"
                                                FontSize="13"
                                                FontFamily="Consolas" />
                                </StackPanel>
                                <ui:Button Grid.Column="1"
                                           Command="{Binding CopyHttpCommand}"
                                           Style="{StaticResource NeonCopyBtnStyle}"
                                           BorderBrush="#4Dff00aa"
                                           VerticalAlignment="Center">
                                    <ui:Button.Effect>
                                        <DropShadowEffect Color="#ff00aa"
                                                          BlurRadius="10"
                                                          ShadowDepth="0"
                                                          Opacity="0.4" />
                                    </ui:Button.Effect>
                                    <ui:SymbolIcon FontSize="20">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol"
                                                        Value="Copy24" />
                                                <Setter Property="Foreground"
                                                        Value="#ff00aa" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHttpCopied}"
                                                                 Value="True">
                                                        <Setter Property="Symbol"
                                                                Value="Checkmark24" />
                                                        <Setter Property="Foreground"
                                                                Value="#00ff88" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <Border Background="#0DFFFFFF"
                                Padding="16"
                                CornerRadius="16"
                                Margin="0,0,0,16"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="🔗"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="VLESS ССЫЛКА (Прямой импорт)"
                                                   Foreground="#00f2ff"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                    </StackPanel>
                                    <ui:TextBox Text="{Binding VlessLink, Mode=OneWay}"
                                                IsReadOnly="True"
                                                AcceptsReturn="True"
                                                TextWrapping="Wrap"
                                                MaxHeight="60"
                                                Background="Transparent"
                                                Foreground="#E6FFFFFF"
                                                BorderThickness="0"
                                                Padding="0"
                                                FontSize="12"
                                                FontFamily="Consolas">
                                        <ui:TextBox.Resources>
                                            <Style TargetType="ScrollBar"
                                                   BasedOn="{StaticResource InvisibleScrollBar}" />
                                        </ui:TextBox.Resources>
                                    </ui:TextBox>
                                </StackPanel>
                                <ui:Button Grid.Column="1"
                                           Command="{Binding CopyVlessCommand}"
                                           Style="{StaticResource NeonCopyBtnStyle}"
                                           BorderBrush="#4D00f2ff"
                                           VerticalAlignment="Center">
                                    <ui:Button.Effect>
                                        <DropShadowEffect Color="#00f2ff"
                                                          BlurRadius="10"
                                                          ShadowDepth="0"
                                                          Opacity="0.4" />
                                    </ui:Button.Effect>
                                    <ui:SymbolIcon FontSize="20">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol"
                                                        Value="Copy24" />
                                                <Setter Property="Foreground"
                                                        Value="#00f2ff" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVlessCopied}"
                                                                 Value="True">
                                                        <Setter Property="Symbol"
                                                                Value="Checkmark24" />
                                                        <Setter Property="Foreground"
                                                                Value="#00ff88" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <Border Background="#0DFFFFFF"
                                Padding="16"
                                CornerRadius="16"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="📄"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="CLIENT CONFIG JSON (Nekobox)"
                                                   Foreground="#ffaa00"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                    </StackPanel>
                                    <ScrollViewer MaxHeight="120"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="ScrollBar"
                                                   BasedOn="{StaticResource InvisibleScrollBar}" />
                                        </ScrollViewer.Resources>
                                        <TextBlock Text="{Binding ClientJson}"
                                                   Foreground="#ffaa00"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </StackPanel>
                                <ui:Button Grid.Column="1"
                                           Command="{Binding CopyJsonCommand}"
                                           Style="{StaticResource NeonCopyBtnStyle}"
                                           BorderBrush="#4Dffaa00"
                                           VerticalAlignment="Top">
                                    <ui:Button.Effect>
                                        <DropShadowEffect Color="#ffaa00"
                                                          BlurRadius="10"
                                                          ShadowDepth="0"
                                                          Opacity="0.4" />
                                    </ui:Button.Effect>
                                    <ui:SymbolIcon FontSize="20">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol"
                                                        Value="Copy24" />
                                                <Setter Property="Foreground"
                                                        Value="#ffaa00" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsJsonCopied}"
                                                                 Value="True">
                                                        <Setter Property="Symbol"
                                                                Value="Checkmark24" />
                                                        <Setter Property="Foreground"
                                                                Value="#00ff88" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </ui:Button>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <ui:Button Grid.Row="3"
                               Command="{Binding CloseWindowCommand}"
                               Content="✅ ГОТОВО, ЗАКРЫТЬ"
                               HorizontalAlignment="Stretch"
                               Padding="0,14"
                               Margin="0,24,0,0"
                               Background="#00ff88"
                               Foreground="Black"
                               FontWeight="ExtraBold"
                               Cursor="Hand">
                        <ui:Button.Effect>
                            <DropShadowEffect Color="#00ff88"
                                              BlurRadius="15"
                                              ShadowDepth="0"
                                              Opacity="0.4" />
                        </ui:Button.Effect>
                    </ui:Button>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>