<ui:FluentWindow x:Class="KoFFPanel.Presentation.Features.Terminal.EditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding WindowTitle}"
                 Height="700"
                 Width="1000"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#1e1e1e"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding WindowTitle}"
                     Background="Transparent"
                     Foreground="#cccccc"
                     Padding="10,5" />

        <Border Grid.Row="1"
                Background="Transparent"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <ui:Button Command="{Binding SaveCommand}"
                               Background="#0e639c"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="12,6"
                               Margin="0,0,8,0"
                               Cursor="Hand"
                               ToolTip="Сохранить изменения на сервере (Ctrl+S)">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24"
                                           Foreground="White"
                                           Margin="0,0,6,0"
                                           FontSize="16" />
                            <TextBlock Text="Сохранить"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                        </StackPanel>
                    </ui:Button>

                    <ui:Button Command="{Binding SaveAsCommand}"
                               Background="Transparent"
                               Foreground="#cccccc"
                               BorderBrush="#333333"
                               BorderThickness="1"
                               Padding="10,6"
                               Margin="0,0,16,0"
                               Cursor="Hand"
                               ToolTip="Создать копию файла на сервере">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="SaveCopy24"
                                           Foreground="#cccccc"
                                           Margin="0,0,6,0"
                                           FontSize="16" />
                            <TextBlock Text="Сохранить как..."
                                       FontSize="13" />
                        </StackPanel>
                    </ui:Button>

                    <Rectangle Width="1"
                               Fill="#333333"
                               Margin="0,4,16,4" />

                    <ui:Button Command="{Binding UndoCommand}"
                               Background="Transparent"
                               Foreground="#cccccc"
                               BorderThickness="0"
                               Padding="8"
                               Margin="0,0,4,0"
                               Cursor="Hand"
                               ToolTip="Отменить (Ctrl+Z)">
                        <ui:SymbolIcon Symbol="ArrowUndo24"
                                       FontSize="16" />
                    </ui:Button>

                    <ui:Button Command="{Binding RedoCommand}"
                               Background="Transparent"
                               Foreground="#cccccc"
                               BorderThickness="0"
                               Padding="8"
                               Margin="0,0,16,0"
                               Cursor="Hand"
                               ToolTip="Вернуть (Ctrl+Y)">
                        <ui:SymbolIcon Symbol="ArrowRedo24"
                                       FontSize="16" />
                    </ui:Button>

                    <Rectangle Width="1"
                               Fill="#333333"
                               Margin="0,4,16,4" />

                    <ui:Button Command="{Binding SearchCommand}"
                               Background="Transparent"
                               Foreground="#cccccc"
                               BorderThickness="0"
                               Padding="8"
                               Cursor="Hand"
                               ToolTip="Поиск по файлу (Ctrl+F)">
                        <ui:SymbolIcon Symbol="Search24"
                                       FontSize="16" />
                    </ui:Button>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding FileStateStatus}"
                           Foreground="{Binding FileStateColor}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="13" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#1e1e1e">
            <wv2:WebView2 x:Name="EditorWebView"
                          DefaultBackgroundColor="Transparent" />
        </Border>

        <Border Grid.Row="3"
                Background="#007acc"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:ProgressRing IsIndeterminate="True"
                                     Foreground="White"
                                     Width="14"
                                     Height="14"
                                     Margin="0,0,8,0" />
                    <TextBlock Text="Сохранение и проверка на сервере..."
                               Foreground="White"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Visibility="{Binding IsSaveComplete, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:SymbolIcon Symbol="{Binding VerifyIcon}"
                                   Foreground="White"
                                   FontSize="14"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                    <TextBlock Text="{Binding VerifyMessage}"
                               Foreground="White"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="{Binding CursorPosition}"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />

                <TextBlock Grid.Column="3"
                           Text="{Binding EditorLanguage, StringFormat='Язык: {0}'}"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>