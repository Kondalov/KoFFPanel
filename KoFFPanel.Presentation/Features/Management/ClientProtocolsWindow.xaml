<ui:FluentWindow x:Class="KoFFPanel.Presentation.Features.Management.ClientProtocolsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:converters="clr-namespace:KoFFPanel.Presentation.Converters"
                 Title="{Binding WindowTitle}"
                 Height="720"
                 Width="600"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="CanResize"
                 MinHeight="600"
                 MinWidth="500">

    <ui:FluentWindow.Resources>
        <converters:BooleanToVisibilityInvertibleConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="NeonCopyBtnStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Background"
                    Value="#0AFFFFFF" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="8" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="CornerRadius"
                    Value="8" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#1AFFFFFF" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="1" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Border BorderThickness="0,3,0,0">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">
                <GradientStop Color="#bd93f9"
                              Offset="0" />
                <GradientStop Color="#00f2ff"
                              Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid Margin="32,20,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,24"
                        VerticalAlignment="Center">
                <Border Width="48"
                        Height="48"
                        CornerRadius="14"
                        Margin="0,0,16,0"
                        BorderThickness="1"
                        BorderBrush="#4Dbd93f9">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop Color="#26bd93f9"
                                          Offset="0" />
                            <GradientStop Color="#2600f2ff"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <ui:SymbolIcon Symbol="Apps24"
                                   Foreground="#bd93f9"
                                   FontSize="24" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Доступ к протоколам"
                               Foreground="#B3FFFFFF"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Email}"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="ExtraBlack" />
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,-12,0">
                <StackPanel Margin="0,0,12,0">
                    <StackPanel Visibility="{Binding IsTrustTunnelMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}">

                        <Border Background="#1A00f2ff"
                                BorderBrush="#4D00f2ff"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding SupportsVless}" Value="False"/>
                                                <Condition Binding="{Binding SupportsHysteria2}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,12"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="🌐"
                                               FontSize="16"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="HTTP ПОДПИСКА (Hiddify / v2rayNG)"
                                               Foreground="#00f2ff"
                                               FontSize="16"
                                               FontWeight="Bold" />
                                </StackPanel>
                                <TextBlock Text="Главная ссылка для автоматического обновления всех протоколов."
                                           Foreground="#B3FFFFFF"
                                           FontSize="12"
                                           Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Text="{Binding HttpLink}"
                                                IsReadOnly="True"
                                                Foreground="White"
                                                FontWeight="Bold"
                                                Background="#0AFFFFFF"
                                                BorderThickness="1"
                                                BorderBrush="#1AFFFFFF"
                                                Height="36" />
                                    <ui:Button Grid.Column="2"
                                               Command="{Binding CopyHttpCommand}"
                                               Height="36"
                                               Background="#1A00f2ff"
                                               BorderThickness="1"
                                               BorderBrush="#3300f2ff"
                                               Cursor="Hand"
                                               Style="{StaticResource NeonCopyBtnStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Copy24"
                                                           Foreground="#00f2ff"
                                                           Margin="0,0,6,0" />
                                            <TextBlock Foreground="#00f2ff"
                                                       FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"
                                                                Value="Копировать" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHttpCopied}"
                                                                         Value="True">
                                                                <Setter Property="Text"
                                                                        Value="Скопировано" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0DFFFFFF"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SupportsVless}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="⚡"
                                                   FontSize="16"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="VLESS (Reality) — Прямая ссылка"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold" />
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1"
                                                     IsChecked="{Binding IsVlessEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalAlignment="Center" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Text="{Binding VlessLink}"
                                                IsReadOnly="True"
                                                Foreground="#B3FFFFFF"
                                                FontWeight="Bold"
                                                Background="#0AFFFFFF"
                                                BorderThickness="1"
                                                BorderBrush="#1AFFFFFF"
                                                Height="36" />
                                    <ui:Button Grid.Column="2"
                                               Command="{Binding CopyVlessCommand}"
                                               Height="36"
                                               Background="#1AFFFFFF"
                                               BorderThickness="1"
                                               BorderBrush="#33FFFFFF"
                                               Cursor="Hand"
                                               Style="{StaticResource NeonCopyBtnStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Copy24"
                                                           Foreground="White"
                                                           Margin="0,0,6,0" />
                                            <TextBlock Foreground="White"
                                                       FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"
                                                                Value="Копировать" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVlessCopied}"
                                                                         Value="True">
                                                                <Setter Property="Text"
                                                                        Value="Скопировано" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0DFFFFFF"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SupportsHysteria2}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="🚀"
                                                   FontSize="16"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="Hysteria 2 — Прямая ссылка"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold" />
                                        <Border Background="#1Aff00aa"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="8,0,0,0">
                                            <TextBlock Text="UDP"
                                                       Foreground="#ff00aa"
                                                       FontSize="10"
                                                       FontWeight="Bold" />
                                        </Border>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1"
                                                     IsChecked="{Binding IsHysteria2Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalAlignment="Center" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Text="{Binding Hysteria2Link}"
                                                IsReadOnly="True"
                                                Foreground="#B3FFFFFF"
                                                FontWeight="Bold"
                                                Background="#0AFFFFFF"
                                                BorderThickness="1"
                                                BorderBrush="#1AFFFFFF"
                                                Height="36" />
                                    <ui:Button Grid.Column="2"
                                               Command="{Binding CopyHysteria2Command}"
                                               Height="36"
                                               Background="#1Abd93f9"
                                               BorderThickness="1"
                                               BorderBrush="#33bd93f9"
                                               Cursor="Hand"
                                               Style="{StaticResource NeonCopyBtnStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Copy24"
                                                           Foreground="#bd93f9"
                                                           Margin="0,0,6,0" />
                                            <TextBlock Foreground="#bd93f9"
                                                       FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"
                                                                Value="Копировать" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHysteria2Copied}"
                                                                         Value="True">
                                                                <Setter Property="Text"
                                                                        Value="Скопировано" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Background="#0DFFFFFF"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,0,12">
                                    <TextBlock Text="🛡️"
                                               FontSize="16"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="TrustTunnel (MASQUE HTTP/3)"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="Bold" />
                                    <Border Background="#1Aff00aa"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="АДМИН ДОСТУП"
                                                   Foreground="#ff00aa"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Данные для ручного ввода в официальное приложение TrustTunnel."
                                           Foreground="#B3FFFFFF"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12" />

                                <Border Background="#1AFFFFFF" CornerRadius="8" Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Address:" Foreground="#88FFFFFF" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TtServerAddress}" IsReadOnly="True" Background="#0DFFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#33FFFFFF" Padding="8,6" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="1" Text="Hostname:" Foreground="#88FFFFFF" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TtDomainName}" IsReadOnly="True" Background="#0DFFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#33FFFFFF" Padding="8,6" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="2" Text="Username:" Foreground="#88FFFFFF" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TtUsername}" IsReadOnly="True" Background="#1A50fa7b" Foreground="White" BorderThickness="1" BorderBrush="#50fa7b" Padding="8,6" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="3" Text="Password:" Foreground="#88FFFFFF" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TtPassword}" IsReadOnly="True" Background="#1A00f2ff" Foreground="White" BorderThickness="1" BorderBrush="#00f2ff" Padding="8,6" FontSize="12" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
                <ui:Button Command="{Binding CancelCommand}"
                           Content="Отмена"
                           Background="#1AFFFFFF"
                           Foreground="#B3FFFFFF"
                           BorderThickness="1"
                           BorderBrush="#33FFFFFF"
                           Padding="24,12"
                           Cursor="Hand"
                           Margin="0,0,12,0" />
                <ui:Button Command="{Binding SaveCommand}"
                           Content="Сохранить настройки"
                           Foreground="Black"
                           FontWeight="Bold"
                           BorderThickness="0"
                           Padding="24,12"
                           Cursor="Hand">
                    <ui:Button.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop Color="#bd93f9"
                                          Offset="0" />
                            <GradientStop Color="#00f2ff"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </ui:Button.Background>
                </ui:Button>
            </StackPanel>
        </Grid>
    </Border>
</ui:FluentWindow>