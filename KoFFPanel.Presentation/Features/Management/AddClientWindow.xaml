<ui:FluentWindow x:Class="KoFFPanel.Presentation.Features.Management.AddClientWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding WindowTitle}"
                 MinHeight="500"
                 Height="700"
                 Width="540"
                 MinWidth="500"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="CanResize">

    <Border BorderThickness="0,3,0,0">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">
                <GradientStop Color="#ff00aa"
                              Offset="0" />
                <GradientStop Color="#7000ff"
                              Offset="0.5" />
                <GradientStop Color="#00f2ff"
                              Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid Margin="32,20,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,24"
                        VerticalAlignment="Center">
                <Border Width="48"
                        Height="48"
                        CornerRadius="14"
                        Margin="0,0,16,0"
                        BorderThickness="1"
                        BorderBrush="#4Dff00aa">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop Color="#26ff00aa"
                                          Offset="0" />
                            <GradientStop Color="#267000ff"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="👤"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20" />
                </Border>
                <TextBlock Text="{Binding WindowTitle}"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="ExtraBlack"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Name -->
                    <RowDefinition Height="Auto" /> <!-- Limit/Expiry -->
                    <RowDefinition Height="*" />    <!-- Note (Flexible) -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="👤" FontSize="14" Foreground="#B3FFFFFF" Margin="0,0,8,0" />
                        <TextBlock Text="Имя пользователя" Foreground="#B3FFFFFF" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="(Только латиница/цифры)" Foreground="#59FFFFFF" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ui:TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Например: Kostya_Phone"
                                Foreground="White" FontWeight="Bold" Background="#0DFFFFFF" BorderBrush="#1AFFFFFF"
                                FontSize="15" Padding="14,10" Height="44" IsReadOnly="{Binding IsEditMode}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📊" FontSize="14" Foreground="#B3FFFFFF" Margin="0,0,8,0" />
                            <TextBlock Text="Лимит" Foreground="#B3FFFFFF" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="(ГБ, 0 = Безлимит)" Foreground="#59FFFFFF" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ui:TextBox Text="{Binding TrafficLimitGb, UpdateSourceTrigger=PropertyChanged}"
                                    Foreground="White" FontWeight="Bold" Background="#0DFFFFFF" BorderBrush="#1AFFFFFF"
                                    FontSize="15" Padding="14,10" Height="44" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📅" FontSize="14" Foreground="#B3FFFFFF" Margin="0,0,8,0" />
                            <TextBlock Text="Истекает" Foreground="#B3FFFFFF" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                        <DatePicker SelectedDate="{Binding ExpiryDate}"
                                    FontSize="15" FontWeight="Bold" Height="44"
                                    Background="#0DFFFFFF" Foreground="White" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,0,0,0" VerticalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="📝" FontSize="14" Foreground="#B3FFFFFF" Margin="0,0,8,0" />
                        <TextBlock Text="Заметка" Foreground="#B3FFFFFF" FontSize="13" FontWeight="SemiBold" />
                    </StackPanel>
                    <ui:TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Контакт, Telegram, устройство..."
                                Foreground="White" FontWeight="Bold" Background="#0DFFFFFF" BorderBrush="#1AFFFFFF"
                                FontSize="15" Padding="14,10" Height="44" />
                </StackPanel>
            </Grid>

                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <Border Background="#1Aff4444"
                            BorderBrush="#4Dff4444"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,6"
                            Margin="0,0,0,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#ffff4444"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <ui:Button Command="{Binding CancelCommand}"
                                   Content="Отмена"
                                   Background="#1AFFFFFF"
                                   Foreground="#B3FFFFFF"
                                   BorderThickness="1"
                                   BorderBrush="#33FFFFFF"
                                   Padding="24,12"
                                   Cursor="Hand"
                                   Margin="0,0,12,0" />
                        <ui:Button Command="{Binding SaveCommand}"
                                   Content="{Binding ActionButtonText}"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   BorderThickness="0"
                                   Padding="32,12"
                                   Cursor="Hand">
                            <ui:Button.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#ffaa00"
                                                  Offset="0" />
                                    <GradientStop Color="#ff8800"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </ui:Button.Background>
                        </ui:Button>
                        </StackPanel>
                        </StackPanel>        </Grid>
    </Border>
</ui:FluentWindow>