<ui:FluentWindow x:Class="KoFFPanel.Presentation.Features.Deploy.DeployWizardWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Мастер установки"
                 Width="700"
                 Height="780"
                 MinWidth="650"
                 MinHeight="700"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <Style x:Key="KernelCardRadioStyle"
               TargetType="RadioButton">
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="VerticalAlignment"
                    Value="Stretch" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="CardBorder"
                                Background="#08FFFFFF"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="2"
                                CornerRadius="16"
                                Padding="16"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0" />
                            </Border.RenderTransform>
                            <Grid>
                                <Border x:Name="CheckBadge"
                                        Width="20"
                                        Height="20"
                                        Background="#00f2ff"
                                        CornerRadius="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="-6,-6,0,0"
                                        Visibility="Collapsed">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00f2ff"
                                                          BlurRadius="10"
                                                          ShadowDepth="0"
                                                          Opacity="0.8" />
                                    </Border.Effect>
                                    <TextBlock Text="✓"
                                               Foreground="#000000"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="CardBorder"
                                        Property="Background"
                                        Value="#1AFFFFFF" />
                                <Setter TargetName="CardBorder"
                                        Property="BorderBrush"
                                        Value="#4DFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="CardBorder"
                                        Property="BorderBrush"
                                        Value="#00f2ff" />
                                <Setter TargetName="CardBorder"
                                        Property="Background"
                                        Value="#0A00f2ff" />
                                <Setter TargetName="CheckBadge"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonCancelBtnStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Background"
                    Value="#1AFFFFFF" />
            <Setter Property="BorderBrush"
                    Value="#33FFFFFF" />
            <Setter Property="Foreground"
                    Value="#B3FFFFFF" />
            <Setter Property="Padding"
                    Value="0,14" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#26FFFFFF" />
                    <Setter Property="Foreground"
                            Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NeonInstallBtnStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0,14" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#00ff88"
                                      Offset="0" />
                        <GradientStop Color="#00cc6a"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00ff88"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.4" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00ff88"
                                              BlurRadius="20"
                                              ShadowDepth="0"
                                              Opacity="0.8" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Мастер установки"
                     Background="Transparent"
                     Foreground="#ffffff"
                     Padding="15,5" />

        <Grid Grid.Row="1"
              Margin="16,10,16,16">
            <Border Background="#E614141E"
                    CornerRadius="20"
                    BorderThickness="1"
                    BorderBrush="#1AFFFFFF">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="30"
                                      ShadowDepth="10"
                                      Opacity="0.5" />
                </Border.Effect>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,4">
                            <ui:SymbolIcon Symbol="Rocket24"
                                           Foreground="#00f2ff"
                                           FontSize="24"
                                           Margin="0,0,10,0" />
                            <TextBlock Text="МАСТЕР УСТАНОВКИ"
                                       FontSize="20"
                                       FontWeight="ExtraBold"
                                       Foreground="White" />
                        </StackPanel>
                        <TextBlock Text="Выберите ядро и отметьте протоколы для развертывания"
                                   Foreground="#B3FFFFFF"
                                   FontSize="12"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <RadioButton Grid.Column="0"
                                     GroupName="CoreSelection"
                                     Style="{StaticResource KernelCardRadioStyle}"
                                     IsChecked="{Binding IsXraySelected}"
                                     IsEnabled="{Binding IsNotInstalling}">
                            <StackPanel HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ShieldCheckmark24"
                                               Foreground="#00f2ff"
                                               FontSize="32"
                                               Margin="0,0,0,10" />
                                <TextBlock Text="XRAY-CORE"
                                           Foreground="White"
                                           FontWeight="ExtraBold"
                                           FontSize="14"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="TCP протоколы"
                                           Foreground="#a0aabf"
                                           FontSize="10"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Grid.Column="2"
                                     GroupName="CoreSelection"
                                     Style="{StaticResource KernelCardRadioStyle}"
                                     IsChecked="{Binding IsSingBoxSelected}"
                                     IsEnabled="{Binding IsNotInstalling}">
                            <StackPanel HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Flash24"
                                               Foreground="#ffaa00"
                                               FontSize="32"
                                               Margin="0,0,0,10" />
                                <TextBlock Text="SING-BOX"
                                           Foreground="White"
                                           FontWeight="ExtraBold"
                                           FontSize="14"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="UDP/TCP протоколы"
                                           Foreground="#a0aabf"
                                           FontSize="10"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Grid.Column="4"
                                     GroupName="CoreSelection"
                                     Style="{StaticResource KernelCardRadioStyle}"
                                     IsChecked="{Binding IsTrustTunnelSelected}"
                                     IsEnabled="{Binding IsNotInstalling}">
                            <StackPanel HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ShieldKeyhole24"
                                               Foreground="#50fa7b"
                                               FontSize="32"
                                               Margin="0,0,0,10" />
                                <TextBlock Text="TRUSTTUNNEL"
                                           Foreground="White"
                                           FontWeight="ExtraBold"
                                           FontSize="14"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="MASQUE HTTP/3"
                                           Foreground="#a0aabf"
                                           FontSize="10"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding AvailableProtocols}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0AFFFFFF"
                                            BorderBrush="#1AFFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="16"
                                            Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>

                                            <ui:ToggleSwitch Grid.Column="0"
                                                             IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,16,0" />

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Builder.DisplayName}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="15"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="{Binding ValidationMessage}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground"
                                                                    Value="#00ff88" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}"
                                                                             Value="False">
                                                                    <Setter Property="Foreground"
                                                                            Value="#ff4444" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSelected}"
                                                                             Value="False">
                                                                    <Setter Property="Foreground"
                                                                            Value="#666666" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="Порт:"
                                                           Foreground="#B3FFFFFF"
                                                           FontSize="11"
                                                           Margin="0,0,0,4" />
                                                <ui:TextBox Text="{Binding PortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            IsEnabled="{Binding IsSelected}"
                                                            TextAlignment="Center"
                                                            FontWeight="Bold"
                                                            FontSize="16"
                                                            Height="36">
                                                    <ui:TextBox.Style>
                                                        <Style TargetType="ui:TextBox"
                                                               BasedOn="{StaticResource {x:Type ui:TextBox}}">
                                                            <Setter Property="BorderBrush"
                                                                    Value="#33FFFFFF" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}"
                                                                             Value="False">
                                                                    <Setter Property="BorderBrush"
                                                                            Value="#ff4444" />
                                                                    <Setter Property="BorderThickness"
                                                                            Value="2" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSelected}"
                                                                             Value="False">
                                                                    <Setter Property="Opacity"
                                                                            Value="0.3" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:TextBox.Style>
                                                </ui:TextBox>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="3"
                               Text="{Binding StatusMessage}"
                               Foreground="#00ff88"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"
                               FontWeight="SemiBold"
                               FontSize="12"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Command="{Binding CancelCommand}"
                                   Content="ОТМЕНА"
                                   Style="{StaticResource NeonCancelBtnStyle}"
                                   IsEnabled="{Binding IsNotInstalling}" />
                        <ui:Button Grid.Column="2"
                                   Command="{Binding StartInstallCommand}"
                                   Content="НАЧАТЬ УСТАНОВКУ"
                                   Style="{StaticResource NeonInstallBtnStyle}"
                                   IsEnabled="{Binding IsNotInstalling}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>