<ui:FluentWindow x:Class="KoFFPanel.Presentation.Features.Deploy.InstallationSuccessWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Установка завершена"
                 Width="600"
                 Height="700"
                 WindowStartupLocation="CenterScreen"
                 Background="#0a0a0a"
                 ExtendsContentIntoTitleBar="True">

    <Grid Margin="24">
        <Border Background="#E614141E"
                CornerRadius="20"
                BorderThickness="1"
                BorderBrush="#3300ff88">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                   Foreground="#00ff88"
                                   FontSize="56"
                                   Margin="0,0,0,16"
                                   HorizontalAlignment="Center">
                        <ui:SymbolIcon.Effect>
                            <DropShadowEffect Color="#00ff88"
                                              BlurRadius="20"
                                              ShadowDepth="0"
                                              Opacity="0.5" />
                        </ui:SymbolIcon.Effect>
                    </ui:SymbolIcon>
                    <TextBlock Text="СЕРВЕР ГОТОВ К РАБОТЕ!"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Старые версии удалены. Скопируйте настройки для Hiddify."
                               Foreground="#B3FFFFFF"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <Border Background="#0DFFFFFF"
                                Padding="16"
                                CornerRadius="12"
                                Margin="0,0,0,16"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,8">
                                    <TextBlock Text="🌐"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="HTTP ССЫЛКА (ПОРТ 8080):"
                                               Foreground="#ff00aa"
                                               FontSize="11"
                                               FontWeight="Bold" />
                                </StackPanel>
                                <ui:TextBox Text="{Binding HttpLink, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Background="#1A000000"
                                            Foreground="White"
                                            BorderBrush="#33ff00aa"
                                            Padding="12"
                                            FontSize="13"
                                            FontFamily="Consolas" />
                            </StackPanel>
                        </Border>

                        <Border Background="#0DFFFFFF"
                                Padding="16"
                                CornerRadius="12"
                                Margin="0,0,0,16"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,8">
                                    <TextBlock Text="🔗"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="VLESS ССЫЛКА (HIDDIFY 4.1.1):"
                                               Foreground="#00f2ff"
                                               FontSize="11"
                                               FontWeight="Bold" />
                                </StackPanel>
                                <ui:TextBox Text="{Binding VlessLink, Mode=OneWay}"
                                            IsReadOnly="True"
                                            AcceptsReturn="True"
                                            Background="#1A000000"
                                            Foreground="White"
                                            BorderBrush="#3300f2ff"
                                            Padding="12"
                                            FontSize="12"
                                            FontFamily="Consolas"
                                            TextWrapping="Wrap"
                                            Height="80" />
                            </StackPanel>
                        </Border>

                        <Border Background="#0DFFFFFF"
                                Padding="16"
                                CornerRadius="12"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,8">
                                    <TextBlock Text="📄"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="CLIENT CONFIG JSON:"
                                               Foreground="#ffaa00"
                                               FontSize="11"
                                               FontWeight="Bold" />
                                </StackPanel>
                                <ui:TextBox Text="{Binding ClientJson, Mode=OneWay}"
                                            IsReadOnly="True"
                                            AcceptsReturn="True"
                                            Background="#1A000000"
                                            Foreground="#ffaa00"
                                            BorderBrush="#33ffaa00"
                                            Padding="12"
                                            FontSize="11"
                                            FontFamily="Consolas"
                                            Height="140"
                                            VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ui:Button Grid.Row="2"
                           Content="СКОПИРОВАЛ, ЗАКРЫТЬ"
                           HorizontalAlignment="Stretch"
                           Padding="0,14"
                           Margin="0,20,0,0"
                           Background="#00ff88"
                           Foreground="Black"
                           FontWeight="ExtraBold"
                           Click="CloseClick">
                    <ui:Button.Effect>
                        <DropShadowEffect Color="#00ff88"
                                          BlurRadius="15"
                                          ShadowDepth="0"
                                          Opacity="0.4" />
                    </ui:Button.Effect>
                </ui:Button>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>